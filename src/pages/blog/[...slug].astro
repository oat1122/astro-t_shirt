---
import Layout from '@/layouts/Layout.astro';
import Navbar from '@/components/Navbar.astro';
import BlogGrid from '@/components/blog/BlogGrid.astro';
import ArticleHeader from '@/components/blog/ArticleHeader.astro';
import ArticleCover from '@/components/blog/ArticleCover.astro';
import ArticleShare from '@/components/blog/ArticleShare.astro';
import BlogSidebar from '@/components/blog/sidebar/BlogSidebar.astro';
import { getCollection, render } from 'astro:content';
import { SITE } from '@/consts';
import favicon from '@/assets/favicon.png';

export async function getStaticPaths() {
  const posts = (await getCollection('blog')).filter((p) => !p.data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const d = post.data;

// URL absolute (เทียบ Astro.site) สำหรับ OG image + JSON-LD
const ogImage = d.cover ? new URL(d.cover.src, Astro.site).toString() : undefined;

const articleJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: d.title,
  description: d.description,
  ...(ogImage && { image: ogImage }),
  author: { '@type': 'Person', name: d.author },
  publisher: {
    '@type': 'Organization',
    name: SITE.name,
    logo: { '@type': 'ImageObject', url: new URL(favicon.src, Astro.site).toString() },
  },
  datePublished: d.publishedAt.toISOString(),
  ...(d.updatedAt && { dateModified: d.updatedAt.toISOString() }),
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': new URL(`/blog/${post.id}`, Astro.site).toString(),
  },
};
---

<Layout title={d.title} description={d.description} image={ogImage} type="article" jsonLd={articleJsonLd}>
  <div class="min-h-screen bg-white p-2 sm:p-4 md:p-6 font-sans">
    <div class="max-w-[1400px] mx-auto bg-[#FAFAFA] rounded-[2rem] sm:rounded-[3rem] overflow-hidden relative shadow-sm border border-gray-100">

      <Navbar />

      <main class="px-4 sm:px-8 lg:px-12 pt-8 pb-20">

        <ArticleHeader title={d.title} author={d.author} tags={d.tags} publishedAt={d.publishedAt} />

        <ArticleCover cover={d.cover} alt={d.coverAlt || d.title} />

        <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-16">
          {/* คอลัมน์ซ้าย: เนื้อหาบทความ */}
          <div class="lg:col-span-8 xl:col-span-9">
            <article class="prose prose-lg prose-gray max-w-none">
              <Content />
            </article>

            <div class="mt-12">
              <ArticleShare tags={d.tags} />
            </div>
          </div>

          {/* คอลัมน์ขวา: Sidebar */}
          <div class="lg:col-span-4 xl:col-span-3">
            <div class="sticky top-8">
              <BlogSidebar currentPostId={post.id} />
            </div>
          </div>
        </div>

        {/* บทความที่เกี่ยวข้อง — ดึงจาก collection จริง, กันบทความปัจจุบัน, ซ่อนเองถ้าไม่มี */}
        <div class="mt-20">
          <BlogGrid title="บทความที่น่าสนใจเพิ่มเติม" excludeId={post.id} showViewAll={false} />
        </div>

      </main>

    </div>
  </div>
</Layout>
