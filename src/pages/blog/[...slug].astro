---
import Layout from '@/layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = (await getCollection('blog')).filter((p) => !p.data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const d = post.data;

const articleJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: d.title,
  description: d.description,
  author: { '@type': 'Person', name: d.author },
  datePublished: d.publishedAt.toISOString(),
  ...(d.updatedAt && { dateModified: d.updatedAt.toISOString() }),
};
---

<Layout title={d.title} description={d.description} type="article" jsonLd={articleJsonLd}>
  <main class="mx-auto max-w-3xl px-4 py-16">
    <a href="/blog" class="text-muted-foreground text-sm hover:underline">← กลับไปบทความ</a>
    <h1 class="mt-4 text-3xl font-bold">{d.title}</h1>
    <p class="text-muted-foreground mt-2 text-sm">
      {
        d.publishedAt.toLocaleDateString('th-TH', {
          year: 'numeric',
          month: 'long',
          day: 'numeric',
        })
      } · {d.author}
    </p>
    <article class="prose mt-8 max-w-none">
      <Content />
    </article>
  </main>
</Layout>
