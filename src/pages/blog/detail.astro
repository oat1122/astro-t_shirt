---
import Layout from '@/layouts/Layout.astro';
import Navbar from '@/components/Navbar.astro';
import BlogGrid from '@/components/blog/BlogGrid.astro';
---

<Layout 
  title="วิธีเลือกเนื้อผ้าทำเสื้อยืดให้เหมาะกับแบรนด์ของคุณ | ธน พลัส 153"
  description="เคล็ดลับการเลือกเนื้อผ้าให้ตรงกับกลุ่มเป้าหมายและดีไซน์ของแบรนด์คุณ"
>
  <div class="min-h-screen bg-white p-2 sm:p-4 md:p-6 font-sans">
    <div class="max-w-[1400px] mx-auto bg-[#FAFAFA] rounded-[2rem] sm:rounded-[3rem] overflow-hidden relative shadow-sm border border-gray-100">

      <Navbar />

      <main class="px-4 sm:px-8 lg:px-12 pt-8 pb-20">
        
        {/* Article Header */}
        <div class="max-w-4xl mx-auto mt-8 mb-12 text-center">
          <a href="/blog" class="inline-flex items-center text-sm font-medium text-gray-500 hover:text-gray-900 mb-8 transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mr-2"><path d="m15 18-6-6 6-6"/></svg>
            กลับหน้าบทความ
          </a>
          
          <div class="flex items-center justify-center gap-3 text-sm text-gray-500 mb-6">
            <span class="bg-blue-50 text-blue-700 px-3 py-1 rounded-full font-semibold text-xs tracking-wide">เนื้อผ้า</span>
            <span>•</span>
            <span>12 พฤษภาคม 2026</span>
          </div>
          
          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-gray-900 tracking-tight leading-[1.15] mb-8">
            วิธีเลือกเนื้อผ้าทำเสื้อยืด<br/>ให้เหมาะกับแบรนด์ของคุณ
          </h1>
          
          <div class="flex items-center justify-center gap-4">
            <div class="w-12 h-12 rounded-full bg-gray-200 overflow-hidden">
               <img src="https://images.unsplash.com/photo-1472099645785-5658abf4ff4e?auto=format&fit=crop&q=80&w=100" alt="Author" class="w-full h-full object-cover"/>
            </div>
            <div class="text-left">
              <p class="text-sm font-bold text-gray-900">ผู้เชี่ยวชาญด้านเนื้อผ้า</p>
              <p class="text-xs text-gray-500">ทีมงาน Thana Plus 153</p>
            </div>
          </div>
        </div>

        {/* Cover Image */}
        <div class="max-w-5xl mx-auto mb-16 rounded-[2rem] sm:rounded-[3rem] overflow-hidden shadow-xl aspect-video bg-gray-100">
          <img src="https://images.unsplash.com/photo-1576566588028-4147f3842f27?auto=format&fit=crop&q=80&w=2000" alt="Cover" class="w-full h-full object-cover" />
        </div>

        {/* Article Content - Prose */}
        <article class="max-w-3xl mx-auto prose prose-lg prose-gray">
          <p class="lead text-xl text-gray-600 mb-8 font-medium">
            การสร้างแบรนด์เสื้อผ้าให้เป็นที่จดจำ นอกจากการออกแบบที่สวยงามแล้ว "เนื้อผ้า" คือหัวใจสำคัญที่จะทำให้ลูกค้ากลับมาซื้อซ้ำ วันนี้เราจะพาไปทำความรู้จักกับเนื้อผ้ายอดฮิตที่เหมาะกับการทำเสื้อยืด
          </p>

          <h2 class="text-2xl font-bold text-gray-900 mt-12 mb-4">1. ผ้า Cotton 100% (ผ้าฝ้ายแท้)</h2>
          <p class="text-gray-600 leading-relaxed mb-6">
            ผ้า Cotton หรือผ้าฝ้ายธรรมชาติ เป็นเนื้อผ้าที่ได้รับความนิยมมากที่สุดในการทำเสื้อยืด เนื่องจากมีคุณสมบัติเด่นคือ ระบายอากาศได้ดีเยี่ยม ซับเหงื่อได้ดี นุ่มสบายเมื่อสัมผัสผิว เหมาะกับอากาศร้อนแบบประเทศไทย
          </p>
          <ul class="list-disc pl-6 text-gray-600 mb-8 space-y-2">
            <li><strong>Cotton No.20:</strong> เส้นด้ายหนา ทนทาน อยู่ทรง</li>
            <li><strong>Cotton No.32:</strong> เส้นด้ายบางลง นุ่ม ใส่สบาย (ยอดฮิตที่สุด)</li>
            <li><strong>Cotton Comb:</strong> ผ่านกระบวนการสางเส้นด้าย เนื้อผ้าจะเนียนละเอียดและพรีเมียมที่สุด</li>
          </ul>

          <h2 class="text-2xl font-bold text-gray-900 mt-12 mb-4">2. ผ้า TC (Cotton ผสม Polyester)</h2>
          <p class="text-gray-600 leading-relaxed mb-6">
            เป็นการผสมผสานระหว่าง Cotton (ประมาณ 35%) และ Polyester (ประมาณ 65%) ข้อดีคือเนื้อผ้าจะมีความคงทน ไม่ย้วยง่าย ยับยาก รีดง่าย และมีราคาที่ย่อมเยากว่า Cotton 100% แต่การระบายอากาศอาจจะไม่ดีเท่า
          </p>

          <blockquote class="border-l-4 border-blue-600 pl-6 my-10 italic text-xl text-gray-700">
            "เนื้อผ้าที่ดีคือเนื้อผ้าที่ตอบโจทย์ Lifestyle ของกลุ่มเป้าหมาย หากทำแบรนด์สตรีทแวร์อาจเน้นผ้าที่หนาและอยู่ทรง แต่ถ้าทำเสื้อออกกำลังกายควรเน้นผ้าที่ระบายอากาศและยืดหยุ่นสูง"
          </blockquote>

          <h2 class="text-2xl font-bold text-gray-900 mt-12 mb-4">สรุปการเลือกเนื้อผ้า</h2>
          <p class="text-gray-600 leading-relaxed mb-6">
            หากแบรนด์ของคุณเน้นความพรีเมียม สวมใส่สบาย <strong>Cotton Comb</strong> คือคำตอบ แต่หากต้องการทำเสื้อกิจกรรม หรือยูนิฟอร์มที่ต้องการความทนทานและดูแลง่าย <strong>ผ้า TC หรือ TK</strong> อาจจะตอบโจทย์มากกว่า
          </p>
        </article>

        {/* Tags and Share */}
        <div class="max-w-3xl mx-auto mt-16 pt-8 border-t border-gray-200 flex flex-col sm:flex-row items-center justify-between gap-6">
          <div class="flex items-center gap-3">
             <span class="text-sm font-semibold text-gray-900">Tags:</span>
             <a href="#" class="px-3 py-1 bg-gray-100 hover:bg-gray-200 rounded-full text-xs font-medium text-gray-600 transition-colors">สร้างแบรนด์</a>
             <a href="#" class="px-3 py-1 bg-gray-100 hover:bg-gray-200 rounded-full text-xs font-medium text-gray-600 transition-colors">เนื้อผ้า</a>
             <a href="#" class="px-3 py-1 bg-gray-100 hover:bg-gray-200 rounded-full text-xs font-medium text-gray-600 transition-colors">มือใหม่</a>
          </div>
          <div class="flex items-center gap-4">
             <span class="text-sm font-semibold text-gray-900">แชร์บทความ:</span>
             <button class="w-8 h-8 rounded-full bg-gray-100 hover:bg-gray-200 flex items-center justify-center text-gray-600 transition-colors">f</button>
             <button class="w-8 h-8 rounded-full bg-gray-100 hover:bg-gray-200 flex items-center justify-center text-gray-600 transition-colors">X</button>
             <button class="w-8 h-8 rounded-full bg-gray-100 hover:bg-gray-200 flex items-center justify-center text-gray-600 transition-colors">in</button>
          </div>
        </div>

        {/* Divider */}
        <div class="max-w-4xl mx-auto my-20 border-t border-gray-200"></div>

        {/* Related Articles - Reusing BlogGrid */}
        <div class="mt-20">
          <div class="mb-10 text-center">
            <h2 class="text-3xl font-bold text-gray-900">บทความที่น่าสนใจเพิ่มเติม</h2>
          </div>
          <BlogGrid />
        </div>

      </main>

    </div>
  </div>
</Layout>
