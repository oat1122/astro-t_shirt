---
import Layout from '@/layouts/Layout.astro';
import { getCollection } from 'astro:content';
import {
  Card,
  CardHeader,
  CardTitle,
  CardDescription,
  CardFooter,
} from '@/components/starwind/card';
import { Button } from '@/components/starwind/button';

const posts = (await getCollection('blog'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf());
---

<Layout title="บทความ" description="ข่าวสารและบทความจาก Astro T-Shirt">
  <main class="mx-auto max-w-3xl px-4 py-16">
    <h1 class="mb-8 text-3xl font-bold">บทความ</h1>
    <div class="space-y-6">
      {
        posts.map((post) => (
          <Card>
            <CardHeader>
              <CardTitle>{post.data.title}</CardTitle>
              <CardDescription>
                {post.data.publishedAt.toLocaleDateString('th-TH', {
                  year: 'numeric',
                  month: 'long',
                  day: 'numeric',
                })}{' '}
                · {post.data.author}
              </CardDescription>
            </CardHeader>
            <CardFooter>
              <Button href={`/blog/${post.id}`} variant="ghost">
                อ่านต่อ →
              </Button>
            </CardFooter>
          </Card>
        ))
      }
    </div>
  </main>
</Layout>
