---
import Layout from '@/layouts/Layout.astro';
import { Button } from '@/components/starwind/button';

---

<Layout title="Stripo - Fresh & Stylish">
  <div class="min-h-screen bg-white p-2 sm:p-4 md:p-6 font-sans">
    <div class="max-w-[1400px] mx-auto bg-[#FAFAFA] rounded-[2rem] sm:rounded-[3rem] overflow-hidden relative shadow-sm border border-gray-100">
      
      {/* Header */}
      <header class="flex items-center justify-between px-8 py-6 lg:px-12">
        <div class="flex items-center gap-2">
          <div class="w-8 h-8 rounded-full bg-[#E54524] flex items-center justify-center text-white font-bold italic relative overflow-hidden">
            <span class="absolute inset-0 bg-white/20 transform -skew-x-12 translate-x-1/2"></span>
            <span class="relative z-10">S</span>
          </div>
          <span class="text-xl font-bold tracking-tight">stripo</span>
        </div>

        <nav class="hidden md:flex items-center gap-8 text-sm font-medium">
          <a href="#" class="flex items-center gap-1 hover:text-gray-600 transition-colors">Products <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg></a>
          <a href="#" class="hover:text-gray-600 transition-colors">Sale</a>
          <a href="#" class="hover:text-gray-600 transition-colors">Gift</a>
          <a href="#" class="hover:text-gray-600 transition-colors">About</a>
        </nav>

        <div class="flex items-center gap-6 text-sm font-medium">
          <div class="relative cursor-pointer">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/><path d="M3 6h18"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
            <span class="absolute -top-1.5 -right-1.5 bg-[#E54524] text-white text-[10px] w-4 h-4 flex items-center justify-center rounded-full font-bold">3</span>
          </div>
          <div class="hidden sm:flex items-center gap-1 cursor-pointer">
            Eng <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
          </div>
          <a href="#" class="hidden sm:block hover:text-gray-600 transition-colors">Account</a>
        </div>
      </header>

      {/* Main Content */}
      <main class="px-8 lg:px-12 pt-8 pb-12">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-start relative">
          
          {/* Left Column - Typography & CTAs */}
          <div class="lg:col-span-7 flex flex-col z-10 pt-10">
            
            <div class="flex flex-col sm:flex-row gap-6 sm:gap-12 mb-10 text-gray-800">
              <div class="flex items-center gap-3">
                <p class="text-sm md:text-base leading-tight max-w-[140px]">Hello Brooklyn!<br/>welcome to Stripo</p>
                <div class="w-16 h-8 rounded-full overflow-hidden border border-gray-200">
                  <img src="https://images.unsplash.com/photo-1517841905240-472988babdf9?auto=format&fit=crop&q=80&w=200" alt="Brooklyn" class="w-full h-full object-cover" />
                </div>
              </div>
              <p class="text-sm md:text-base leading-tight max-w-[180px]">Beautifully efficient apparel for the modern world</p>
            </div>

            <h1 class="text-[5rem] sm:text-[7rem] lg:text-[8rem] leading-[0.9] font-bold tracking-tight text-gray-900 mb-6 flex flex-col">
              <span>Fresh &</span>
              <span class="flex items-center gap-4">
                <span class="text-gray-400 font-light tracking-normal">Stylish</span>
              </span>
            </h1>

            <div class="flex flex-col sm:flex-row items-start sm:items-center gap-8 mt-12">
              <p class="text-gray-600 max-w-[200px] leading-snug">Your Gateway to Chic and Contemporary Living</p>
              <div class="flex items-center gap-3">
                <Button class="rounded-full bg-black hover:bg-gray-800 text-white px-8 py-6 text-base shadow-lg transition-transform hover:scale-105">
                  Explore Our Store
                </Button>
                <Button class="rounded-full w-12 h-12 p-0 bg-black hover:bg-gray-800 text-white flex items-center justify-center shadow-lg transition-transform hover:scale-105">
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17 17 7"/><path d="M7 7h10v10"/></svg>
                </Button>
              </div>
            </div>

          </div>

          {/* Right Column - Large Image */}
          <div class="lg:col-span-5 relative mt-12 lg:mt-0 lg:absolute lg:right-0 lg:top-0 lg:w-[45%] lg:h-[120%] pointer-events-none">
            {/* Background Circle */}
            <div class="absolute inset-0 bg-[#F0F0F0] rounded-full aspect-square w-[80%] mx-auto lg:mx-0 lg:w-full lg:-right-[10%] lg:-top-[10%] -z-10 mix-blend-multiply"></div>
            
            {/* Main Model Image */}
            <img 
              src="/images/home/hero-img.png" 
              alt="Main Model" 
              class="w-full h-auto object-cover rounded-[3rem] lg:rounded-none lg:bg-transparent lg:object-contain relative z-0 pointer-events-auto transform scale-110 translate-y-12 lg:translate-y-0"
              style="mask-image: linear-gradient(to bottom, black 80%, transparent 100%); -webkit-mask-image: linear-gradient(to bottom, black 80%, transparent 100%);"
            />

            {/* Floating Social Proof */}
            <div class="absolute top-[10%] right-0 lg:-right-8 bg-white/80 backdrop-blur-md px-4 py-3 rounded-2xl shadow-sm border border-gray-100 flex flex-col gap-2 pointer-events-auto">
              <div class="flex items-center gap-1 text-lg">
                <span>🔥</span><span>👍</span><span>💙</span><span>✌️</span><span>🏖️</span>
              </div>
              <p class="text-xs font-semibold text-gray-800 underline decoration-gray-300 underline-offset-4">Loved From 500k Users</p>
            </div>

            {/* Scroll Down Indicator */}
            <div class="hidden lg:flex absolute bottom-[20%] -right-12 items-center gap-2 transform rotate-90 text-sm font-medium tracking-wide text-gray-500 pointer-events-auto">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="-rotate-90"><path d="M12 5v14"/><path d="m19 12-7 7-7-7"/></svg>
              Scroll Down
            </div>
          </div>

        </div>

        {/* Collections Cards - Bottom */}
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mt-32 lg:mt-24 relative z-20">
          
          {/* Card 1 */}
          <div class="bg-white rounded-3xl p-4 flex gap-4 items-center shadow-[0_4px_20px_-10px_rgba(0,0,0,0.05)] border border-gray-100 group cursor-pointer hover:shadow-md transition-shadow">
            <div class="w-24 h-32 rounded-2xl overflow-hidden bg-gray-100 shrink-0">
              <img src="/images/home/men's%20collection.png" alt="Men's Collection" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
            </div>
            <div class="flex flex-col justify-center relative w-full h-full">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="absolute top-0 right-0 text-gray-400 group-hover:text-black transition-colors"><path d="M7 17 17 7"/><path d="M7 7h10v10"/></svg>
              <h3 class="text-xl font-bold mb-1">Men's<br/><span class="text-gray-400 font-normal">Collection</span></h3>
              <p class="text-[10px] text-gray-500 mt-2 leading-tight">The Essence of Modern<br/>Sophistication</p>
            </div>
          </div>

          {/* Card 2 */}
          <div class="bg-white rounded-3xl p-4 flex gap-4 items-center shadow-[0_4px_20px_-10px_rgba(0,0,0,0.05)] border border-gray-100 group cursor-pointer hover:shadow-md transition-shadow">
            <div class="w-24 h-32 rounded-2xl overflow-hidden bg-gray-100 shrink-0">
              <img src="/images/home/girl's%20collection.png" alt="Girl's Collection" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
            </div>
            <div class="flex flex-col justify-center relative w-full h-full">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="absolute top-0 right-0 text-gray-400 group-hover:text-black transition-colors"><path d="M7 17 17 7"/><path d="M7 7h10v10"/></svg>
              <h3 class="text-xl font-bold mb-1">Girl's<br/><span class="text-gray-400 font-normal">Collection</span></h3>
              <p class="text-[10px] text-gray-500 mt-2 leading-tight">The Essence of Modern<br/>Sophistication</p>
            </div>
          </div>

          {/* Card 3 + Next Button */}
          <div class="flex gap-4 items-center">
            <div class="bg-white rounded-3xl p-4 flex gap-4 items-center shadow-[0_4px_20px_-10px_rgba(0,0,0,0.05)] border border-gray-100 flex-1 group cursor-pointer hover:shadow-md transition-shadow">
              <div class="w-24 h-32 rounded-2xl overflow-hidden bg-gray-100 shrink-0">
                <img src="https://images.unsplash.com/photo-1519238263530-99abad672f69?auto=format&fit=crop&q=80&w=400" alt="Kid's Collection" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
              </div>
              <div class="flex flex-col justify-center relative w-full h-full">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="absolute top-0 right-0 text-gray-400 group-hover:text-black transition-colors"><path d="M7 17 17 7"/><path d="M7 7h10v10"/></svg>
                <h3 class="text-xl font-bold mb-1">Kid's<br/><span class="text-gray-400 font-normal">Collection</span></h3>
                <p class="text-[10px] text-gray-500 mt-2 leading-tight">The Essence of Modern<br/>Sophistication</p>
              </div>
            </div>
            
            <button class="w-16 h-16 rounded-full bg-black text-white flex items-center justify-center shrink-0 hover:bg-gray-800 transition-transform hover:scale-105 shadow-lg">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17 17 7"/><path d="M7 7h10v10"/></svg>
            </button>
          </div>

        </div>

      </main>
    </div>
  </div>
</Layout>
