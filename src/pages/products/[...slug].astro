---
import PageLayout from '@/layouts/PageLayout.astro';
import { getCollection, render } from 'astro:content';

import ProductGallery from '@/components/products/ProductGallery.astro';
import Faq from '@/components/Faq.astro';
import { buildFaqJsonLd } from '@/lib/faq';
import { SITE } from '@/consts';

// SSG: สร้างหน้าทุกสินค้า ณ build time
export async function getStaticPaths() {
  const products = await getCollection('products');
  return products.map((product) => ({
    params: { slug: product.id },
    props: { product },
  }));
}

const { product } = Astro.props;
const { Content } = await render(product);
const d = product.data;

// JSON-LD แบบ Product (ดีต่อ SEO/Rich results)
const productJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: d.title,
  description: d.description,
  image: new URL(d.image.src, Astro.site).toString(),
  brand: {
    '@type': 'Brand',
    name: SITE.name,
  },
  offers: {
    '@type': 'Offer',
    url: new URL(Astro.url.pathname, Astro.site).toString(),
    priceCurrency: 'THB',
    price: d.price,
    availability: d.inStock
      ? 'https://schema.org/InStock'
      : 'https://schema.org/OutOfStock',
    itemCondition: 'https://schema.org/NewCondition',
  },
};

// FAQPage JSON-LD จาก frontmatter (null ถ้าไม่มี faq) — ต่อท้าย Product ในหน้าเดียวได้
const faqJsonLd = buildFaqJsonLd(d.faq);
---

<PageLayout
  title={d.title}
  description={d.description}
  type="product"
  image={d.image.src}
  jsonLd={[productJsonLd, ...(faqJsonLd ? [faqJsonLd] : [])]}
>
  <div class="mx-auto max-w-7xl">
    <div class="mb-12">
      <a href="/products" class="inline-flex items-center text-sm font-medium text-muted-foreground hover:text-foreground transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mr-2 h-4 w-4"><path d="m15 18-6-6 6-6"/></svg>
        กลับไปหน้ารวมสินค้า
      </a>
    </div>

    <div class="max-w-3xl mx-auto text-center mb-16">
      <h1 class="text-4xl md:text-5xl font-bold tracking-tight mb-4">{d.title}</h1>
      {d.price > 0 && (
        <p class="text-2xl font-semibold text-primary mb-6">
          ฿{d.price.toLocaleString('th-TH')}
        </p>
      )}
      <div class="prose prose-lg mx-auto text-muted-foreground">
        <p>{d.description}</p>
      </div>
      
      <article class="prose prose-neutral mx-auto mt-8 max-w-none prose-headings:font-bold prose-a:text-primary text-left">
        <Content />
      </article>
    </div>

    {/* Full Masonry Gallery */}
    <ProductGallery images={[d.image, ...(d.gallery || [])]} altPrefix={d.title} />

    {/* FAQ ที่มองเห็นได้ — เรนเดอร์จาก data เดียวกับ FAQPage JSON-LD */}
    <div class="max-w-3xl mx-auto">
      <Faq items={d.faq} />
    </div>
  </div>
</PageLayout>
