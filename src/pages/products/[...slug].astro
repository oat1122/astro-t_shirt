---
import Layout from '@/layouts/Layout.astro';
import { Image } from 'astro:assets';
import { getCollection, render } from 'astro:content';
import { Badge } from '@/components/starwind/badge';
import { Button } from '@/components/starwind/button';

// SSG: สร้างหน้าทุกสินค้า ณ build time
export async function getStaticPaths() {
  const products = await getCollection('products');
  return products.map((product) => ({
    params: { slug: product.id },
    props: { product },
  }));
}

const { product } = Astro.props;
const { Content } = await render(product);
const d = product.data;

// JSON-LD แบบ Product (ดีต่อ SEO/Rich results)
const productJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: d.title,
  description: d.description,
  image: new URL(d.image.src, Astro.site).toString(),
  offers: {
    '@type': 'Offer',
    price: d.price,
    priceCurrency: 'THB',
    availability: d.inStock
      ? 'https://schema.org/InStock'
      : 'https://schema.org/OutOfStock',
  },
};
---

<Layout
  title={d.title}
  description={d.description}
  type="product"
  image={d.image.src}
  jsonLd={productJsonLd}
>
  <main class="mx-auto max-w-4xl px-4 py-16">
    <div class="grid gap-8 md:grid-cols-2">
      <Image
        src={d.image}
        alt={d.imageAlt}
        width={800}
        height={800}
        class="rounded-lg border border-border"
      />
      <div>
        <h1 class="text-3xl font-bold">{d.title}</h1>
        <p class="text-muted-foreground mt-2">{d.description}</p>
        <p class="text-primary mt-4 text-2xl font-bold">
          ฿{d.price.toLocaleString('th-TH')}
        </p>

        {
          d.colors.length > 0 && (
            <div class="mt-4 flex flex-wrap gap-2">
              {d.colors.map((c) => (
                <Badge variant="secondary">{c}</Badge>
              ))}
            </div>
          )
        }
        {
          d.sizes.length > 0 && (
            <div class="mt-2 flex flex-wrap gap-2">
              {d.sizes.map((s) => (
                <Badge variant="outline">{s}</Badge>
              ))}
            </div>
          )
        }

        <Button class="mt-6 w-full" disabled={!d.inStock}>
          {d.inStock ? 'เพิ่มลงตะกร้า' : 'สินค้าหมด'}
        </Button>
      </div>
    </div>

    <article class="prose mt-12 max-w-none">
      <Content />
    </article>
  </main>
</Layout>
