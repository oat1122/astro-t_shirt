---
import PageLayout from '@/layouts/PageLayout.astro';
import { getCollection } from 'astro:content';
import PortfolioCard from '@/components/products/PortfolioCard.astro';
import { SITE } from '@/consts';

const products = (await getCollection('products')).sort(
  (a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf(),
);

// JSON-LD ItemList Schema for better SEO of category pages
const itemListElement = products.map((product, index) => ({
  '@type': 'ListItem',
  position: index + 1,
  name: product.data.title,
  url: new URL(`/products/${product.id}`, Astro.site).toString(),
  image: new URL(product.data.image.src, Astro.site).toString(),
}));

const listJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  itemListElement,
};

// Breadcrumb JSON-LD — หน้าแรก → ผลงาน (สัญญาณโครงสร้างไซต์ของหน้า listing)
const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'หน้าแรก', item: Astro.site?.toString() },
    { '@type': 'ListItem', position: 2, name: 'ผลงาน', item: new URL('/products', Astro.site).toString() },
  ],
};
---

<PageLayout
  title="ผลงานรับผลิตเสื้อ ตัวอย่างงานสกรีนและตัดเย็บ"
  description="รวมผลงานรับผลิตเสื้อยืด โปโล และงานสกรีนจาก เสื้อแท้ (ธน พลัส 153) ตั้งแต่ออกแบบ ตัดเย็บ จนถึงงานสกรีน DTG/DTF ผลิตด้วยมาตรฐานพรีเมียมทุกตัว"
  jsonLd={[listJsonLd, breadcrumbJsonLd]}
>
    <!-- header section -->
    <div class="mb-16 text-center max-w-2xl mx-auto">
      <h1 class="text-4xl md:text-5xl font-bold tracking-tight mb-4">
        ผลงานรับผลิตเสื้อ
        <span class="block text-xl md:text-2xl font-normal text-muted-foreground mt-2">Our Portfolio</span>
      </h1>
      <p class="text-lg text-muted-foreground">
        ผลงานบางส่วนจาก {SITE.name} <strong class="font-semibold text-foreground">โรงงานรับผลิตเสื้อครบวงจร</strong>
        ตั้งแต่ออกแบบ ตัดเย็บ จนถึงงานสกรีน ค้นพบคุณภาพที่แตกต่าง ด้วยการผลิตที่ใส่ใจทุกขั้นตอน
      </p>
    </div>
    
    <!-- masonry grid -->
    <div class="columns-1 sm:columns-2 lg:columns-3 xl:columns-4 gap-4 sm:gap-6">
      {
        products.map((product) => (
          <PortfolioCard 
            id={product.id}
            title={product.data.title}
            description={product.data.description}
            image={product.data.image}
            imageAlt={product.data.imageAlt}
          />
        ))
      }
    </div>
    
    {products.length === 0 && (
      <div class="text-center py-20 text-muted-foreground">
        <p class="text-xl">Coming soon...</p>
      </div>
    )}

    <!-- testimonials section -->
    <section class="mt-32 mb-16 text-center">
      <div class="inline-block px-5 py-1.5 rounded-full border border-border text-sm font-medium mb-8">
        รีวิวจากลูกค้า
      </div>
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold mb-3 tracking-tight">ลูกค้าหลากหลายวงการไว้วางใจ</h2>
      <p class="text-xl md:text-2xl text-muted-foreground mb-16 font-light">ทั้งสตาร์ทอัพ องค์กร และเจ้าของแบรนด์</p>
      
      <div class="grid md:grid-cols-3 gap-8 md:gap-12 text-left max-w-5xl mx-auto px-4">
        <!-- Testimonial 1 -->
        <div class="space-y-4">
          <div class="text-amber-400 text-lg md:text-xl tracking-widest">★★★★★</div>
          <p class="text-muted-foreground leading-relaxed text-sm md:text-base">"คุณภาพเสื้อจากเสื้อแท้ดีเกินคาดมาก งานสกรีนออกมาคมชัดเป๊ะทุกตัว ทีมงานคุยง่ายและใส่ใจรายละเอียด แนะนำเลยครับ!"</p>
          <div class="flex items-center gap-4 mt-6 pt-4">
            <div class="w-12 h-12 bg-secondary/50 rounded-full overflow-hidden flex items-center justify-center text-secondary-foreground font-bold">
              น
            </div>
            <div>
              <h4 class="font-bold text-sm">คุณนภัส ว.</h4>
              <p class="text-xs text-muted-foreground">ผู้ก่อตั้งสตาร์ทอัพ</p>
            </div>
          </div>
        </div>
        
        <!-- Testimonial 2 -->
        <div class="space-y-4">
          <div class="text-amber-400 text-lg md:text-xl tracking-widest">★★★★★</div>
          <p class="text-muted-foreground leading-relaxed text-sm md:text-base">"ทีมเรามองหาพาร์ตเนอร์ที่ยืดหยุ่นและไว้ใจได้สำหรับยูนิฟอร์มคอลเลกชันใหม่ เสื้อแท้ทำได้ตามที่ต้องการเป๊ะ ขั้นตอนราบรื่นและส่งงานตรงเวลา"</p>
          <div class="flex items-center gap-4 mt-6 pt-4">
            <div class="w-12 h-12 bg-secondary/50 rounded-full overflow-hidden flex items-center justify-center text-secondary-foreground font-bold">
              ภ
            </div>
            <div>
              <h4 class="font-bold text-sm">คุณภูริ ก.</h4>
              <p class="text-xs text-muted-foreground">นักออกแบบ UX</p>
            </div>
          </div>
        </div>

        <!-- Testimonial 3 -->
        <div class="space-y-4">
          <div class="text-amber-400 text-lg md:text-xl tracking-widest">★★★★★</div>
          <p class="text-muted-foreground leading-relaxed text-sm md:text-base">"ชอบที่มีตัวเลือกเนื้อผ้าหลากหลายมาก ไม่ว่าจะผ้าคอตตอนพรีเมียมสำหรับสินค้าแบรนด์ หรือผ้ากีฬาระบายอากาศดี เสื้อแท้มีให้เลือกครบทุกแบบ"</p>
          <div class="flex items-center gap-4 mt-6 pt-4">
            <div class="w-12 h-12 bg-secondary/50 rounded-full overflow-hidden flex items-center justify-center text-secondary-foreground font-bold">
              ล
            </div>
            <div>
              <h4 class="font-bold text-sm">คุณลออ อ.</h4>
              <p class="text-xs text-muted-foreground">นักการตลาดดิจิทัล</p>
            </div>
          </div>
        </div>
      </div>
    </section>
</PageLayout>
