---
import PageLayout from '@/layouts/PageLayout.astro';
import { getCollection } from 'astro:content';
import PortfolioCard from '@/components/products/PortfolioCard.astro';
import { SITE } from '@/consts';

const products = (await getCollection('products')).sort(
  (a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf(),
);

// JSON-LD ItemList Schema for better SEO of category pages
const itemListElement = products.map((product, index) => ({
  '@type': 'ListItem',
  position: index + 1,
  url: new URL(`/products/${product.id}`, Astro.site).toString(),
}));

const listJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  itemListElement,
};
---

<PageLayout
  title="Our Portfolio | ผลงานของเรา"
  description="เลือกชมผลงานคอลเลกชันเสื้อยืดดีไซน์พิเศษทั้งหมดของเรา ผลิตด้วยมาตรฐานพรีเมียมจาก Thana Plus 153"
  jsonLd={listJsonLd}
>
    <!-- header section -->
    <div class="mb-16 text-center max-w-2xl mx-auto">
      <h1 class="text-4xl md:text-5xl font-bold tracking-tight mb-4">Our Portfolio</h1>
      <p class="text-lg text-muted-foreground">
        ค้นพบคุณภาพที่แตกต่าง ด้วยการผลิตที่ใส่ใจทุกขั้นตอนจาก {SITE.name}
      </p>
    </div>
    
    <!-- masonry grid -->
    <div class="columns-1 sm:columns-2 lg:columns-3 xl:columns-4 gap-4 sm:gap-6">
      {
        products.map((product) => (
          <PortfolioCard 
            id={product.id}
            title={product.data.title}
            description={product.data.description}
            image={product.data.image}
            imageAlt={product.data.imageAlt}
          />
        ))
      }
    </div>
    
    {products.length === 0 && (
      <div class="text-center py-20 text-muted-foreground">
        <p class="text-xl">Coming soon...</p>
      </div>
    )}

    <!-- testimonials section -->
    <section class="mt-32 mb-16 text-center">
      <div class="inline-block px-5 py-1.5 rounded-full border border-border text-sm font-medium mb-8">
        Testimonials
      </div>
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold mb-3 tracking-tight">Trusted by creatives and leaders</h2>
      <p class="text-xl md:text-2xl text-muted-foreground mb-16 font-light">from various industries</p>
      
      <div class="grid md:grid-cols-3 gap-8 md:gap-12 text-left max-w-5xl mx-auto px-4">
        <!-- Testimonial 1 -->
        <div class="space-y-4">
          <div class="text-amber-400 text-lg md:text-xl tracking-widest">★★★★★</div>
          <p class="text-muted-foreground leading-relaxed text-sm md:text-base">"The quality of the shirts provided by Thana Plus is outstanding! The custom prints came out perfectly and their team was so easy to work with. Highly recommend!"</p>
          <div class="flex items-center gap-4 mt-6 pt-4">
            <div class="w-12 h-12 bg-secondary/50 rounded-full overflow-hidden flex items-center justify-center text-secondary-foreground font-bold">
              J
            </div>
            <div>
              <h4 class="font-bold text-sm">Joao M.</h4>
              <p class="text-xs text-muted-foreground">Startup Founder</p>
            </div>
          </div>
        </div>
        
        <!-- Testimonial 2 -->
        <div class="space-y-4">
          <div class="text-amber-400 text-lg md:text-xl tracking-widest">★★★★★</div>
          <p class="text-muted-foreground leading-relaxed text-sm md:text-base">"Our team needed a flexible and reliable partner for our new uniform collection, and they truly delivered. The process was smooth, and the uniforms were exactly what we needed!"</p>
          <div class="flex items-center gap-4 mt-6 pt-4">
            <div class="w-12 h-12 bg-secondary/50 rounded-full overflow-hidden flex items-center justify-center text-secondary-foreground font-bold">
              B
            </div>
            <div>
              <h4 class="font-bold text-sm">Bruno K.</h4>
              <p class="text-xs text-muted-foreground">UX Designer</p>
            </div>
          </div>
        </div>

        <!-- Testimonial 3 -->
        <div class="space-y-4">
          <div class="text-amber-400 text-lg md:text-xl tracking-widest">★★★★★</div>
          <p class="text-muted-foreground leading-relaxed text-sm md:text-base">"I love the variety of fabric options available! Whether I need premium cotton for our merch or breathable sports wear, Thana Plus always has the perfect option."</p>
          <div class="flex items-center gap-4 mt-6 pt-4">
            <div class="w-12 h-12 bg-secondary/50 rounded-full overflow-hidden flex items-center justify-center text-secondary-foreground font-bold">
              L
            </div>
            <div>
              <h4 class="font-bold text-sm">Lais A.</h4>
              <p class="text-xs text-muted-foreground">Digital Marketer</p>
            </div>
          </div>
        </div>
      </div>
    </section>
</PageLayout>
