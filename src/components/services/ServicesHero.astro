---
// ServicesHero — ส่วนหัวหน้าบริการดีไซน์ใหม่สไตล์ Premium Editorial
// ใช้การแบ่งคอลัมน์ไม่สมมาตร (Asymmetric Split) และสถิติที่จัดแสดงแบบ Grid
import { Button } from '@/components/starwind/button';

interface Props {
  /** จำนวนผลงาน/ตัวอย่างจริง (ดึงจาก collection products) */
  works?: number;
}
const { works = 0 } = Astro.props;

// สถิติความน่าเชื่อถือ
const stats = [
  { value: '10+', label: 'ปีประสบการณ์' },
  { value: `${works.toLocaleString('th-TH')}+`, label: 'ผลงานที่ส่งมอบ' },
  { value: '100%', label: 'ตรวจ QC ทุกตัว' },
] as const;
---

<section class="relative pt-8 pb-16 lg:pt-16 lg:pb-24 overflow-hidden">
  {/* แสงฟุ้งพื้นหลังแบบละเอียดอ่อน */}
  <div class="absolute right-0 top-0 w-[400px] h-[400px] bg-gray-100 rounded-full blur-3xl opacity-60 -z-10 pointer-events-none"></div>

  <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-center">
    {/* ฝั่งซ้าย: เนื้อหาหลักและ CTA */}
    <div class="lg:col-span-7 flex flex-col items-start">
      <div class="inline-flex items-center gap-2 px-3.5 py-1.5 rounded-full bg-gray-50 border border-gray-100 text-xs font-semibold tracking-wider text-gray-500 mb-6 uppercase">
        <span class="inline-block h-1.5 w-1.5 rounded-full bg-gray-900 animate-pulse"></span>
        <span>บริการผลิตเสื้อผ้าสำเร็จรูป</span>
      </div>

      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold tracking-tight leading-[1.1] text-gray-900 mb-6">
        โรงงานผลิตเสื้อผ้า<br />
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-gray-900 to-gray-400">
          ระดับมืออาชีพครบวงจร
        </span>
      </h1>

      <p class="text-gray-600 text-lg sm:text-xl leading-relaxed mb-8 max-w-2xl">
        เราดูแลให้คุณครบทุกมิติ ตั้งแต่การคัดสรรผ้าคุณภาพดี การตัดเย็บที่ประณีต ออกแบบฟรี 
        ไปจนถึงงานพิมพ์และงานสกรีนทุกรูปแบบ ภายใต้การควบคุมมาตรฐานคุณภาพที่เข้มงวด ส่งงานตรงเวลา
      </p>

      <div class="flex flex-col sm:flex-row items-stretch sm:items-center gap-3.5 w-full sm:w-auto">
        <Button
          href="#contact"
          class="rounded-full bg-gray-900 hover:bg-black text-white px-8 h-12 text-base font-semibold shadow-md hover:shadow-xl hover:-translate-y-0.5 transition-all duration-300 gap-2 flex items-center justify-center"
        >
          ขอใบเสนอราคาฟรี
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </Button>
        <a
          href="/products"
          class="inline-flex items-center justify-center rounded-full border border-gray-200 bg-white text-gray-900 hover:bg-gray-50 px-8 h-12 text-base font-semibold hover:-translate-y-0.5 transition-all duration-300 shadow-sm"
        >
          ดูผลงานล่าสุด
        </a>
      </div>
    </div>

    {/* ฝั่งขวา: แผงสถิติแบบพรีเมียม (Grid Display Panel) */}
    <div class="lg:col-span-5 relative">
      <div class="bg-gray-50 border border-gray-100 rounded-[2.5rem] p-8 lg:p-10 shadow-sm relative overflow-hidden group hover:border-gray-200 transition-all duration-500">
        <div class="absolute -right-16 -top-16 w-32 h-32 bg-white/40 rounded-full blur-2xl group-hover:bg-white/60 transition-colors pointer-events-none"></div>
        
        <h3 class="text-xs font-bold uppercase tracking-widest text-gray-400 mb-8 border-b border-gray-200 pb-3">
          ความไว้วางใจและการการันตี · Trust & Specs
        </h3>

        <div class="grid grid-cols-1 sm:grid-cols-3 lg:grid-cols-1 gap-8">
          {stats.map((s, index) => (
            <div class={`flex flex-col ${index !== stats.length - 1 ? 'sm:border-r lg:border-r-0 lg:border-b sm:border-gray-200 lg:border-gray-200 pb-6 pr-4' : 'pb-0'}`}>
              <span class="text-4xl sm:text-5xl font-black tracking-tight text-gray-900 tabular-nums">
                {s.value}
              </span>
              <span class="text-sm font-medium text-gray-500 mt-2">
                {s.label}
              </span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
