---
// ServicePrinting — ส่วนงานสกรีนและงานพิมพ์ผ้าดีไซน์ใหม่สไตล์ Editorial Showcase
// แสดงข้อมูลเทคนิคหลัก 3 แบบที่ดึงและกรองจาก src/lib/services (SERVICES)
// กำหนดภาพด้วย Join Key เพื่อหลีกเลี่ยงการจับคู่ผ่านดัชนีอาร์เรย์
import { Image } from 'astro:assets';
import Icon from '@/components/Icon.astro';
import { SERVICES } from '@/lib/services';

// นำเข้ารูปภาพสำหรับเทคนิคงานสกรีน
import silkScreenImg from '@/assets/home/ScreenServices/Silk Screen.png';
import dftDtgImg from '@/assets/home/ScreenServices/DFT_DTG.png';
import sublimationImg from '@/assets/home/ScreenServices/Sublimation.png';

// จับคู่ Key ใน SERVICES กับตัวแปรภาพที่นำเข้าจริง
const IMAGE_MAP = {
  silk: {
    src: silkScreenImg,
    alt: 'งานซิลค์สกรีน (Silk Screen) ระดับมาตรฐานอุตสาหกรรม',
    badge: 'Silk Screen Printing',
  },
  dtg: {
    src: dftDtgImg,
    alt: 'งานพิมพ์ดิจิทัลระบบ DFT และ DTG ความคมชัดสูง',
    badge: 'Direct-to-Garment / Film',
  },
  sublimation: {
    src: sublimationImg,
    alt: 'งานพิมพ์ซับลิเมชัน (Sublimation) สีสดใสเต็มตัว',
    badge: 'Sublimation Printing',
  },
} as const;

// กรองเฉพาะบริการพิมพ์ผ้าจาก SERVICES
const printingServices = SERVICES.filter((s) => s.printing && s.key && s.key in IMAGE_MAP);
---

<section id="screen" class="scroll-mt-24 mt-24 lg:mt-32">
  <div class="max-w-3xl mb-16 lg:mb-20">
    <div class="flex items-center gap-2 px-3 py-1 rounded-full bg-gray-50 border border-gray-100 text-xs font-semibold tracking-wider text-gray-500 mb-4 uppercase w-fit">
      <span>เทคนิคและนวัตกรรมสกรีน · Print Techniques</span>
    </div>
    <h2 class="text-3xl md:text-4xl lg:text-5xl font-extrabold tracking-tight text-gray-900 mb-5 leading-tight">
      งานสกรีน & งานพิมพ์ระบบดิจิทัล
    </h2>
    <p class="text-gray-600 text-lg leading-relaxed max-w-2xl">
      ตอบสนองทุกงานดีไซน์ที่เป็นเอกลักษณ์ของคุณ ด้วยเทคโนโลยีและช่างพิมพ์ที่มีความชำนาญสูง 
      เลือกใช้เทคนิคที่คุ้มงบและสวยงามที่สุด
    </p>
  </div>

  <div class="space-y-20 lg:space-y-28">
    {printingServices.map((s, index) => {
      // ดึงข้อมูลภาพและข้อความที่ตรงกับคีย์บริการ
      const imgData = IMAGE_MAP[s.key as keyof typeof IMAGE_MAP];
      const isEven = index % 2 === 1;

      return (
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-16 items-center">
          {/* ส่วนเนื้อหาหลัก */}
          <div class={`lg:col-span-5 flex flex-col items-start ${isEven ? 'order-1 lg:order-2' : 'order-1'}`}>
            <span class="inline-flex items-center gap-1.5 text-xs font-bold uppercase tracking-widest text-gray-400 mb-3.5">
              Technique {String(index + 1).padStart(2, '0')}
            </span>
            <h3 class="text-2xl md:text-3xl font-extrabold text-gray-900 mb-4 leading-snug">
              {s.title}
            </h3>
            <p class="text-gray-600 text-base md:text-lg leading-relaxed mb-6">
              {s.description}
            </p>
            
            <ul class="flex flex-col gap-3.5 w-full mb-8">
              {s.points.map((p) => (
                <li class="flex items-start gap-3 text-sm md:text-base text-gray-700">
                  <Icon name="circle-check" size={18} class="text-gray-900 mt-1 flex-shrink-0" />
                  <span class="leading-relaxed">{p}</span>
                </li>
              ))}
            </ul>

            <a
              href="#contact"
              class="inline-flex items-center gap-1.5 text-sm font-bold text-gray-900 hover:text-black border-b-2 border-gray-900 pb-1 transition-colors group"
            >
              ปรึกษาเทคนิคลายพิมพ์นี้
              <svg 
                xmlns="http://www.w3.org/2000/svg" 
                width="16" 
                height="16" 
                viewBox="0 0 24 24" 
                fill="none" 
                stroke="currentColor" 
                stroke-width="2.5" 
                stroke-linecap="round" 
                stroke-linejoin="round" 
                class="transform group-hover:translate-x-1 transition-transform duration-300"
              >
                <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
              </svg>
            </a>
          </div>

          {/* ส่วนแกลเลอรีภาพ */}
          <div class={`lg:col-span-7 ${isEven ? 'order-2 lg:order-1' : 'order-2'} relative group`}>
            {/* โครงกล่องขอบเหลี่ยมมนหรูหราพร้อมเงาลอย */}
            <div class="relative rounded-[2rem] sm:rounded-[2.5rem] overflow-hidden shadow-md group-hover:shadow-xl border border-gray-100 transition-all duration-500">
              <div class="absolute inset-0 bg-black/10 group-hover:bg-transparent transition-colors duration-500 z-10"></div>
              <Image
                src={imgData.src}
                alt={imgData.alt}
                widths={[400, 640, 800]}
                sizes="(min-width: 1024px) 50vw, 100vw"
                class="w-full h-auto object-cover aspect-[4/3] transform group-hover:scale-105 transition-transform duration-700"
              />
              <div class="absolute bottom-5 left-5 z-20 bg-white/95 backdrop-blur-md px-5 py-2.5 rounded-2xl shadow-md border border-white/20">
                <span class="text-gray-900 font-semibold text-xs md:text-sm tracking-wide uppercase">
                  {imgData.badge}
                </span>
              </div>
            </div>
          </div>
        </div>
      );
    })}
  </div>
</section>
