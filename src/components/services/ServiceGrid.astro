---
// ServiceGrid — การ์ดบริการหลักของโรงงาน (data-driven จาก src/lib/services)
// ใช้แหล่งข้อมูลร่วมกับ Service JSON-LD ในหน้า services.astro กัน schema drift
import Icon from '@/components/Icon.astro';
import { SERVICES } from '@/lib/services';
---

<section id="services" class="scroll-mt-24 mt-24 lg:mt-32 container mx-auto px-4 sm:px-6 lg:px-8">
  <div class="max-w-2xl mb-12 lg:mb-16">
    <h2 class="text-3xl md:text-4xl lg:text-5xl font-extrabold tracking-tight text-gray-900 mb-4 leading-tight">
      บริการที่เราดูแลให้คุณ
    </h2>
    <p class="text-gray-600 text-lg leading-relaxed">
      ครอบคลุมทุกความต้องการของการผลิตเสื้อ ตั้งแต่ต้นน้ำถึงปลายน้ำ
      เลือกเฉพาะบริการที่ต้องการ หรือให้เราดูแลแบบครบวงจร
    </p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
    {SERVICES.map((s) => (
      <article class="group flex flex-col h-full bg-white rounded-[2rem] border border-gray-100 p-7 lg:p-8 shadow-sm hover:shadow-xl hover:-translate-y-1 hover:border-gray-200 transition-all duration-300">
        <div class="flex-shrink-0 w-14 h-14 flex items-center justify-center bg-gray-900 text-white rounded-2xl mb-5 group-hover:scale-110 transition-transform duration-300">
          <Icon name={s.icon} size={26} />
        </div>
        <h3 class="text-xl font-bold text-gray-900 mb-2">{s.title}</h3>
        <p class="text-gray-600 leading-relaxed mb-5">{s.description}</p>
        <ul class="mt-auto flex flex-col gap-2.5">
          {s.points.map((p) => (
            <li class="flex items-start gap-2.5 text-sm text-gray-700">
              <Icon name="circle-check" size={18} class="text-gray-900 mt-0.5 flex-shrink-0" />
              <span>{p}</span>
            </li>
          ))}
        </ul>
      </article>
    ))}
  </div>
</section>
