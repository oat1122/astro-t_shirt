---
// ServiceGrid — การ์ดบริการดีไซน์ใหม่สไตล์โมเดิร์นคาร์ด (Data-driven จาก src/lib/services)
// ใช้ key-check สำหรับไอคอน และคง ID สำหรับการเข้าถึงลิงก์อย่างถูกต้อง
import Icon from '@/components/Icon.astro';
import SectionHeading from '@/components/services/SectionHeading.astro';
import { SERVICES } from '@/lib/services';
---

<section id="services" class="scroll-mt-24 mt-24 lg:mt-32">
  <SectionHeading
    eyebrow="บริการหลักของเรา · Main Offerings"
    title="บริการรับผลิตเสื้อสำเร็จรูปครบวงจร"
    intro="ตอบโจทย์ทุกความต้องการของธุรกิจคุณด้วยบริการแบบ One-Stop Service ตั้งแต่ดีไซน์แรกเริ่ม ไปจนถึงขั้นตอนการจัดส่งสินค้าถึงมืออย่างสมบูรณ์แบบ"
  />

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
    {SERVICES.map((s, idx) => (
      <article class="group relative flex flex-col h-full bg-white rounded-[2rem] border border-gray-100 p-8 shadow-sm hover:shadow-xl hover:-translate-y-1.5 hover:border-gray-200 transition-all duration-500 overflow-hidden">
        {/* เลขดัชนีจางๆ ด้านหลัง เพื่อสร้างความลึกของเลย์เอาต์ */}
        <span class="absolute -right-3 -top-6 text-[7.5rem] font-black text-gray-100/60 select-none group-hover:text-gray-200/80 transition-colors duration-500 pointer-events-none tabular-nums">
          {String(idx + 1).padStart(2, '0')}
        </span>

        <div class="relative z-10 flex-shrink-0 w-14 h-14 flex items-center justify-center bg-gray-900 text-white rounded-2xl mb-6 group-hover:bg-black group-hover:scale-110 transition-all duration-500">
          <Icon name={s.icon} size={26} />
        </div>

        <div class="relative z-10">
          <h3 class="text-xl font-bold text-gray-900 mb-3 group-hover:text-black transition-colors">{s.title}</h3>
          <p class="text-gray-600 text-sm md:text-base leading-relaxed mb-6">{s.description}</p>
        </div>

        <ul class="relative z-10 mt-auto flex flex-col gap-3 pt-4 border-t border-gray-100">
          {s.points.map((p) => (
            <li class="flex items-start gap-3 text-sm text-gray-700">
              <span class="mt-0.5 flex-shrink-0 w-5 h-5 flex items-center justify-center bg-gray-50 text-gray-900 rounded-full border border-gray-100 group-hover:bg-gray-900 group-hover:text-white group-hover:border-gray-900 transition-colors duration-500">
                <Icon name="circle-check" size={12} class="flex-shrink-0" />
              </span>
              <span class="leading-snug">{p}</span>
            </li>
          ))}
        </ul>
      </article>
    ))}
  </div>
</section>
