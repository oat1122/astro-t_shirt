---
// ServiceWhyChooseUs — จุดเด่นโรงงานดีไซน์ใหม่สไตล์ Premium Dark Block
// แทนที่การนำเข้าโดยตรงจาก home/WhyChooseUs.astro เพื่อสร้างตัวตนเฉพาะของหน้าบริการ
// นำเข้าข้อมูลจุดเด่นร่วมจาก src/lib/services.ts (WHY_CHOOSE_US)
import { Image } from 'astro:assets';
import Icon from '@/components/Icon.astro';
import DarkSection from '@/components/services/DarkSection.astro';
import Eyebrow from '@/components/services/Eyebrow.astro';
import { WHY_CHOOSE_US } from '@/lib/services';

// นำเข้ารูปภาพประกอบของโรงงาน
import whyChooseImg from '@/assets/home/WhyChooseUsHover.png';
import whyChooseOverlay from '@/assets/home/WhyChooseUs.png';
---

<DarkSection blobClass="-right-[10%] -top-[20%] w-[50%] h-[150%]">
    {/* ฝั่งซ้าย: จุดเด่นการบริการและเหตุผลที่เลือกเรา */}
    <div class="lg:col-span-6 flex flex-col items-start">
      <Eyebrow variant="dark" class="mb-6">ทำไมต้องเลือกเรา · Why Choose Us</Eyebrow>
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold tracking-tight mb-6 leading-tight">
        โรงงานรับผลิตเสื้อผ้าสำเร็จรูป<br />
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-white to-gray-400">
          บริษัท ธน พลัส 153 จำกัด
        </span>
      </h2>
      <p class="text-gray-400 text-base md:text-lg mb-10 leading-relaxed max-w-xl">
        สัมผัสการร่วมงานกับพาร์ทเนอร์ที่พร้อมเติบโตและยกระดับแบรนด์ของคุณ 
        ด้วยโรงงานที่เพียบพร้อมด้วยเทคโนโลยีและทีมงานมืออาชีพที่มีประสบการณ์ยาวนาน
      </p>

      <div class="flex flex-col gap-8 w-full">
        {WHY_CHOOSE_US.map((item) => (
          <div class="flex items-start gap-4 group">
            <div class="bg-white/10 p-3.5 rounded-2xl shrink-0 group-hover:bg-white/20 transition-all duration-300 group-hover:scale-110">
              <Icon name={item.icon} size={26} class="text-white" />
            </div>
            <div>
              <h3 class="text-xl font-bold text-white mb-2">{item.title}</h3>
              <p class="text-gray-400 text-sm leading-relaxed">{item.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>

    {/* ฝั่งขวา: ภาพผลงานและเครื่องจักรโรงงานพร้อมเอฟเฟกต์ CSS-Only Hover */}
    <div class="lg:col-span-6 relative h-[400px] lg:h-[600px] rounded-[2rem] overflow-hidden group border border-white/10 shadow-lg">
      <Image
        src={whyChooseOverlay}
        alt=""
        aria-hidden="true"
        widths={[400, 600, 800, 1000]}
        sizes="(min-width: 1024px) 50vw, 100vw"
        class="absolute inset-0 w-full h-full object-cover pointer-events-none z-10 transition-opacity duration-500 group-hover:opacity-0"
      />
      <Image
        src={whyChooseImg}
        alt="โรงงานผลิตเสื้อ ธน พลัส 153 กำลังตัดเย็บและสกรีนเสื้อเพื่อส่งมอบงานคุณภาพสูง"
        widths={[400, 600, 800, 1000]}
        sizes="(min-width: 1024px) 50vw, 100vw"
        class="w-full h-full object-cover transform group-hover:scale-105 transition-transform duration-700"
      />
    </div>
</DarkSection>
