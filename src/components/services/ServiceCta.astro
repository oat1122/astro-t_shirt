---
// ServiceCta — แถบเรียกให้ติดต่อดีไซน์ใหม่สไตล์ Lead Capture Panel
// แสดงช่องทางการติดต่อหลักสำหรับกระตุ้นการสั่งผลิตจริงอย่างสมบูรณ์แบบ
// ดึงข้อมูลการติดต่อจาก SITE.contact ใน src/consts.ts เพื่อป้องกันการซ้ำซ้อน
import { Button } from '@/components/starwind/button';
import { SITE } from '@/consts';
import Icon from '@/components/Icon.astro';
---

<section id="contact" class="scroll-mt-24 mt-24 lg:mt-32 relative z-20 bg-gray-900 text-white rounded-[3rem] p-10 md:p-16 lg:p-20 overflow-hidden shadow-2xl mx-2 md:mx-0">
  {/* ภาพพื้นหลังประดับจางๆ */}
  <div class="absolute -left-[10%] -bottom-[40%] w-[55%] h-[160%] bg-white/5 rounded-full blur-3xl pointer-events-none"></div>

  <div class="relative z-10 grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-center">
    {/* ฝั่งซ้าย: ข้อมูลโรงงานและคำเชิญชวน */}
    <div class="lg:col-span-7 flex flex-col items-start">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-white/10 text-xs font-semibold tracking-wider text-gray-300 mb-6 uppercase">
        <span>ยินดีให้บริการลูกค้าทุกท่าน · Contact Us</span>
      </div>
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold tracking-tight mb-5 leading-tight">
        พร้อมร่วมงานกับ<br />
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-white to-gray-400">
          ทีมงานมืออาชีพแล้วหรือยัง?
        </span>
      </h2>
      <p class="text-gray-400 text-base md:text-lg leading-relaxed mb-8 max-w-xl">
        คุยรายละเอียดผ้า คิวงานสกรีน ม็อคอัพ หรือขอใบเสนอราคาฟรีได้เลย 
        ทีมงาน Thanaplus ยินดีดูแลคุณตั้งแต่ต้นจนจบงาน
      </p>

      {/* ที่ตั้งสำนักงาน / โรงงาน */}
      <div class="flex items-start gap-3 text-sm text-gray-400 bg-white/5 border border-white/10 rounded-2xl p-4.5 max-w-lg">
        <Icon name="building-factory-2" size={20} class="text-white shrink-0 mt-0.5" />
        <div>
          <strong class="block text-white font-bold mb-1">สถานที่ตั้งโรงงาน (Head Office)</strong>
          <span class="leading-relaxed">{SITE.contact.address}</span>
        </div>
      </div>
    </div>

    {/* ฝั่งขวา: รายชื่อปุ่มช่องทางติดต่อเพื่อรับงานทันที */}
    <div class="lg:col-span-5 w-full">
      <div class="bg-white/5 border border-white/10 rounded-[2rem] p-6 sm:p-8 flex flex-col gap-4.5 relative backdrop-blur-sm">
        <h3 class="text-lg font-bold text-white mb-2 border-b border-white/10 pb-3">
          เลือกช่องทางติดต่อทีมงาน
        </h3>

        {/* LINE Official (Primary Convert Tool) */}
        <Button
          href={SITE.contact.lineLink}
          target="_blank"
          rel="noopener noreferrer"
          class="w-full rounded-full bg-[#06C755] hover:bg-[#05b34c] text-white px-6 h-12 text-base font-semibold shadow-md hover:-translate-y-0.5 transition-all duration-300 gap-2 flex items-center justify-center border-none"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon icon-tabler icons-tabler-outline icon-tabler-brand-line"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M21 11.5c0 -4.694 -4.03 -8.5 -9 -8.5s-9 3.806 -9 8.5c0 4.204 3.208 7.683 7.554 8.362c.328 .062 .772 .216 .884 .555c.105 .317 .07 .814 .034 1.135c-.035 .313 -.168 1.22 -.184 1.4c-.03 .329 -.154 1.28 .665 .698c.819 -.581 4.407 -2.593 6.13 -3.755c4.917 .013 8.917 -3.992 8.917 -8.4" /></svg>
          คุยทาง Line: {SITE.contact.line}
        </Button>

        {/* Phone Call (Secondary) */}
        <Button
          href={SITE.contact.phoneLink}
          class="w-full rounded-full bg-white text-gray-900 hover:bg-gray-100 px-6 h-12 text-base font-semibold shadow-md hover:-translate-y-0.5 transition-all duration-300 gap-2 flex items-center justify-center"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon icon-tabler icons-tabler-outline icon-tabler-phone"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M5 4h4l2 5l-2.5 1.5a11 11 0 0 0 5 5l1.5 -2.5l5 2v4a2 2 0 0 1 -2 2a16 16 0 0 1 -15 -15a2 2 0 0 1 2 -2" /></svg>
          โทรติดต่อ: {SITE.contact.phone}
        </Button>

        {/* Email Mailto */}
        <a
          href={`mailto:${SITE.contact.email}`}
          class="w-full inline-flex items-center justify-center rounded-full border border-white/20 text-gray-300 hover:text-white hover:bg-white/5 px-6 h-12 text-base font-semibold transition-all duration-300 gap-2 hover:-translate-y-0.5 shadow-sm"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon icon-tabler icons-tabler-outline icon-tabler-mail"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M3 7a2 2 0 0 1 2 -2h14a2 2 0 0 1 2 2v10a2 2 0 0 1 -2 2h-14a2 2 0 0 1 -2 -2v-10z" /><path d="M3 7l9 6l9 -6" /></svg>
          ส่งอีเมล: {SITE.contact.email}
        </a>
      </div>
    </div>
  </div>
</section>
