---
// ServiceCta — แถบเรียกให้ติดต่อ (ปิดท้ายหน้าบริการ, โทนดำแบบ WhyChooseUs)
import { Button } from '@/components/starwind/button';
---

<section id="contact" class="scroll-mt-24 mt-24 lg:mt-32 relative z-20 bg-gray-900 text-white rounded-[3rem] p-10 md:p-16 lg:p-20 overflow-hidden shadow-2xl mx-2 md:mx-0">
  {/* Background decorative element */}
  <div class="absolute -left-[10%] -bottom-[40%] w-[55%] h-[160%] bg-white/5 rounded-full blur-3xl pointer-events-none"></div>

  <div class="relative z-10 flex flex-col lg:flex-row lg:items-center lg:justify-between gap-10">
    <div class="max-w-xl">
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold tracking-tight mb-4 leading-tight">
        พร้อมเริ่มผลิตเสื้อของคุณแล้วหรือยัง?
      </h2>
      <p class="text-gray-400 text-lg leading-relaxed">
        ปรึกษาทีมงานได้ฟรี เราช่วยประเมินราคา แนะนำเนื้อผ้าและเทคนิคสกรีนที่เหมาะกับงาน
        พร้อมออกแบบให้ดูก่อนตัดสินใจ
      </p>
    </div>

    <div class="flex flex-col sm:flex-row gap-3 shrink-0">
      <Button
        href="#contact"
        class="rounded-full bg-white text-gray-900 hover:bg-gray-100 px-8 text-base font-semibold shadow-lg hover:-translate-y-0.5 transition-all duration-300 gap-2"
      >
        ปรึกษาฟรี
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </Button>
      <a
        href="/products"
        class="inline-flex items-center justify-center rounded-full border border-white/30 text-white hover:bg-white/10 px-8 h-11 text-base font-semibold transition-colors duration-300"
      >
        ดูผลงาน
      </a>
    </div>
  </div>
</section>
