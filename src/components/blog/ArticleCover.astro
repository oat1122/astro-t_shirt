---
// รูปหน้าปกบทความ — astro:assets <Image> (WebP/AVIF + width/height กัน CLS)
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  cover?: ImageMetadata;
  alt: string;
}

const { cover, alt } = Astro.props;
---

{cover ? (
  <div class="max-w-5xl mx-auto mb-16 rounded-[2rem] sm:rounded-[3rem] overflow-hidden shadow-xl aspect-video bg-gray-100">
    {/* รูปหน้าปกคือ LCP — โหลดทันทีและให้ priority สูง */}
    <Image
      src={cover}
      alt={alt}
      widths={[640, 960, 1280, 1920]}
      sizes="(max-width: 1024px) 100vw, 1024px"
      loading="eager"
      fetchpriority="high"
      class="w-full h-full object-cover"
    />
  </div>
) : (
  <div class="max-w-5xl mx-auto mb-16 rounded-[2rem] sm:rounded-[3rem] overflow-hidden shadow-xl aspect-video bg-gray-100 flex items-center justify-center">
    <span class="text-gray-400">ไม่มีรูปภาพหน้าปก</span>
  </div>
)}
