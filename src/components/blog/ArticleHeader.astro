---
// ส่วนหัวบทความ — ปุ่มกลับ + แท็กแรก/วันที่ + ชื่อเรื่อง + การ์ดผู้เขียน
interface Props {
  title: string;
  author: string;
  tags: string[];
  publishedAt: Date;
}

const { title, author, tags, publishedAt } = Astro.props;
const hasTags = tags.length > 0;
---

<div class="max-w-4xl mx-auto mt-4 mb-12 px-4">
  <div class="mb-10">
    <a href="/blog" class="inline-flex items-center justify-center w-10 h-10 rounded-full bg-white border border-gray-200 text-gray-500 hover:bg-gray-50 hover:text-gray-900 transition-colors shadow-sm group" title="กลับหน้าบทความ">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transform group-hover:-translate-x-0.5 transition-transform"><path d="m15 18-6-6 6-6"/></svg>
    </a>
  </div>

  <div class="flex flex-col md:flex-row md:items-end justify-between gap-8 pb-10">
    <div class="flex-1">
      <div class="flex items-center gap-3 text-sm mb-5">
        {hasTags && (
          <span class="inline-flex items-center px-3.5 py-1.5 rounded-full text-xs font-bold tracking-wide bg-gray-900 text-white">
            {tags[0]}
          </span>
        )}
        {hasTags && <span class="w-1.5 h-1.5 rounded-full bg-gray-300"></span>}
        <time datetime={publishedAt.toISOString()} class="font-medium text-gray-500 flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/></svg>
          {publishedAt.toLocaleDateString('th-TH', { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
      </div>

      <h1 class="text-4xl sm:text-5xl lg:text-[3.5rem] font-bold text-gray-900 tracking-tight leading-[1.15] text-balance">
        {title}
      </h1>
    </div>

    <div class="shrink-0 flex items-center gap-4 bg-white p-2.5 pr-6 rounded-full border border-gray-100 shadow-sm relative top-2">
      <div class="w-12 h-12 rounded-full bg-gradient-to-tr from-blue-100 to-indigo-50 flex items-center justify-center text-blue-600 ring-2 ring-white">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
      </div>
      <div>
        <p class="text-[10px] text-gray-400 font-bold uppercase tracking-widest mb-0.5">Written By</p>
        <p class="text-sm font-bold text-gray-900">{author}</p>
      </div>
    </div>
  </div>
</div>
