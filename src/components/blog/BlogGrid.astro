---
const posts = [
  {
    title: 'วิธีเลือกเนื้อผ้าทำเสื้อยืดให้เหมาะกับแบรนด์ของคุณ',
    category: 'เนื้อผ้า',
    date: '12 พ.ค. 2026',
    image: 'https://images.unsplash.com/photo-1576566588028-4147f3842f27?auto=format&fit=crop&q=80&w=600',
    slug: 'fabric-selection-guide'
  },
  {
    title: 'ความแตกต่างระหว่างงานสกรีน DFT และ ซิลค์สกรีน',
    category: 'งานสกรีน',
    date: '05 พ.ค. 2026',
    image: 'https://images.unsplash.com/photo-1529374255404-311a2a4f1fd9?auto=format&fit=crop&q=80&w=600',
    slug: 'dft-vs-silkscreen'
  },
  {
    title: 'เทรนด์สีเสื้อผ้าและทรงเสื้อยอดฮิตประจำปีนี้',
    category: 'เทรนด์แฟชั่น',
    date: '28 เม.ย. 2026',
    image: 'https://images.unsplash.com/photo-1503342217505-b0a15ec3261c?auto=format&fit=crop&q=80&w=600',
    slug: 'fashion-trends-this-year'
  },
  {
    title: 'เปิดแบรนด์เสื้อผ้าใช้เงินลงทุนเท่าไหร่?',
    category: 'ธุรกิจ',
    date: '15 เม.ย. 2026',
    image: 'https://images.unsplash.com/photo-1441984904996-e0b6ba687e04?auto=format&fit=crop&q=80&w=600',
    slug: 'clothing-brand-investment'
  }
];
---

<section class="mb-24">
  <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-4 mb-10">
    <h2 class="text-3xl font-bold text-gray-900 tracking-tight">บทความล่าสุด</h2>
    <a href="#" class="text-gray-600 font-medium hover:text-gray-900 transition-colors inline-flex items-center gap-1">
      ดูทั้งหมด
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
    </a>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
    {posts.map((post) => (
      <a href={`/blog/${post.slug}`} class="group block bg-white rounded-3xl p-3 border border-transparent hover:border-gray-100 hover:shadow-lg transition-all duration-300">
        <div class="rounded-2xl overflow-hidden mb-5 aspect-[4/3] bg-gray-100">
          <img 
            src={post.image} 
            alt={post.title} 
            class="w-full h-full object-cover transform group-hover:scale-105 transition-transform duration-500" 
            loading="lazy"
          />
        </div>
        <div class="px-2 pb-2">
          <div class="flex items-center justify-between gap-3 text-sm text-gray-500 mb-3">
            <span class="bg-gray-100 px-2.5 py-1 rounded-full text-gray-800 font-medium text-xs whitespace-nowrap">{post.category}</span>
            <span class="text-xs">{post.date}</span>
          </div>
          <h3 class="text-lg font-bold text-gray-900 mb-4 group-hover:text-blue-600 transition-colors line-clamp-2 leading-snug">{post.title}</h3>
          
          <div class="flex items-center text-sm font-semibold text-gray-900 group-hover:text-blue-600">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="mr-2"><circle cx="12" cy="12" r="10"/><polygon points="10 8 16 12 10 16 10 8"/></svg>
            อ่านบทความ
          </div>
        </div>
      </a>
    ))}
  </div>
</section>
