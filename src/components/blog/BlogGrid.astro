---
// กริดบทความ — ดึงจาก collection จริง, เรียงใหม่สุดก่อน, ซ่อนเองถ้าไม่มีบทความ
// ใช้ได้ทั้งหน้า list (บทความล่าสุด) และท้าย detail (บทความที่เกี่ยวข้อง)
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';

import type { CollectionEntry } from 'astro:content';

interface Props {
  /** หัวข้อ section */
  title?: string;
  /** id บทความที่ต้องการตัดออก (เช่น บทความที่กำลังอ่านอยู่) */
  excludeId?: string;
  /** จำนวนสูงสุดที่แสดง */
  limit?: number;
  /** แสดงลิงก์ "ดูทั้งหมด" หรือไม่ */
  showViewAll?: boolean;
  /** ข้อมูลบทความที่ถูกกรองมาแล้ว (ถ้ามี) */
  posts?: CollectionEntry<'blog'>[];
}

const { title = 'บทความล่าสุด', excludeId, limit = 4, showViewAll = true, posts: propPosts } = Astro.props;

const posts = propPosts || (await getCollection('blog'))
  .filter((p) => !p.data.draft && p.id !== excludeId)
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf())
  .slice(0, limit);
---

{posts.length > 0 && (
  <section class="mb-32">
    <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-4 mb-14">
      <h2 class="text-3xl sm:text-4xl font-bold text-gray-900 tracking-tight">{title}</h2>
      {showViewAll && (
        <a href="/blog" class="text-gray-600 font-medium hover:text-gray-900 transition-colors inline-flex items-center gap-1">
          ดูทั้งหมด
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
        </a>
      )}
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-10">
      {posts.map((post) => {
        const d = post.data;
        return (
          <a href={`/blog/${post.id}`} class="group block bg-white rounded-3xl p-3 border border-transparent hover:border-gray-100 hover:shadow-lg transition-all duration-300">
            <div class="rounded-2xl overflow-hidden mb-5 aspect-[4/3] bg-gray-100">
              {d.cover && (
                <Image
                  src={d.cover}
                  alt={d.coverAlt || d.title}
                  widths={[400, 600, 800]}
                  sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 25vw"
                  loading="lazy"
                  class="w-full h-full object-cover transform group-hover:scale-105 transition-transform duration-500"
                />
              )}
            </div>
            <div class="px-2 pb-2">
              <div class="flex items-center justify-between gap-3 text-sm text-gray-500 mb-3">
                {d.tags[0] && (
                  <span class="bg-gray-100 px-2.5 py-1 rounded-full text-gray-800 font-medium text-xs whitespace-nowrap">{d.tags[0]}</span>
                )}
                <span class="text-xs">{d.publishedAt.toLocaleDateString('th-TH', { year: 'numeric', month: 'short', day: 'numeric' })}</span>
              </div>
              <h3 class="text-lg font-bold text-gray-900 mb-4 group-hover:text-blue-600 transition-colors line-clamp-2 leading-snug">{d.title}</h3>

              <div class="flex items-center text-sm font-semibold text-gray-900 group-hover:text-blue-600">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="mr-2"><circle cx="12" cy="12" r="10"/><polygon points="10 8 16 12 10 16 10 8"/></svg>
                อ่านบทความ
              </div>
            </div>
          </a>
        );
      })}
    </div>
  </section>
)}
