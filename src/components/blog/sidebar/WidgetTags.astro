---
import { getCollection } from 'astro:content';

const posts = await getCollection('blog', (p) => !p.data.draft);

const tags = new Set<string>();
posts.forEach(post => {
  if (post.data.tags) {
    post.data.tags.forEach(tag => tags.add(tag));
  }
});
const sortedTags = Array.from(tags).sort();
---

<div class="bg-white rounded-3xl border border-gray-100 p-6 sm:p-8 shadow-sm">
  <div class="flex items-center gap-3 mb-6 pb-4 border-b border-gray-100">
    <div class="w-1.5 h-6 bg-blue-600 rounded-full"></div>
    <h3 class="text-lg font-bold text-gray-900 tracking-tight">TAG BLOG</h3>
  </div>
  
  <div class="flex flex-wrap gap-2">
    {sortedTags.map(tag => (
      <a href={`/tag/${tag}`} class="inline-block bg-gray-50 border border-gray-100 text-gray-600 text-xs font-bold px-3.5 py-1.5 rounded-full hover:bg-gray-900 hover:text-white hover:border-gray-900 transition-colors">
        {tag}
      </a>
    ))}
  </div>
</div>
