---
import { getCollection } from 'astro:content';

const posts = await getCollection('blog', (p) => !p.data.draft);

// Extract and count categories
const categoryCounts = posts.reduce((acc, post) => {
  const cat = post.data.category;
  if (cat) {
    acc[cat] = (acc[cat] || 0) + 1;
  }
  return acc;
}, {} as Record<string, number>);

// Sort categories alphabetically or by count (here by count descending)
const sortedCategories = Object.entries(categoryCounts).sort((a, b) => b[1] - a[1]);
---

<div class="bg-white rounded-3xl border border-gray-100 p-6 sm:p-8 shadow-sm">
  <div class="flex items-center gap-3 mb-6 pb-4 border-b border-gray-100">
    <div class="w-1.5 h-6 bg-blue-600 rounded-full"></div>
    <h3 class="text-lg font-bold text-gray-900 tracking-tight">หมวดหมู่</h3>
  </div>
  
  <ul class="flex flex-col gap-3">
    {sortedCategories.map(([category, count]) => (
      <li>
        <a href={`/category/${category}`} class="group flex items-center justify-between text-gray-600 hover:text-blue-600 transition-colors">
          <span class="font-medium group-hover:-translate-y-0.5 transition-transform">{category}</span>
          <span class="bg-gray-50 text-gray-500 text-xs font-bold px-2.5 py-0.5 rounded-full group-hover:bg-blue-50 group-hover:text-blue-600 transition-colors">
            {count}
          </span>
        </a>
      </li>
    ))}
  </ul>
</div>
