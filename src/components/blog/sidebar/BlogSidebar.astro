---
import WidgetCategories from './WidgetCategories.astro';
import WidgetRecentPosts from './WidgetRecentPosts.astro';
import WidgetTags from './WidgetTags.astro';

interface Props {
  currentPostId?: string;
  class?: string;
}

const { currentPostId, class: className } = Astro.props;
---

<aside class:list={["flex flex-col gap-8", className]}>
  <WidgetCategories />
  <WidgetRecentPosts excludeId={currentPostId} />
  <WidgetTags />
</aside>
