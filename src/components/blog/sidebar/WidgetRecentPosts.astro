---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';

interface Props {
  excludeId?: string;
}
const { excludeId } = Astro.props;

let posts = await getCollection('blog', (p) => !p.data.draft);
if (excludeId) {
  posts = posts.filter((p) => p.id !== excludeId);
}
// Sort by date descending and take top 5
posts = posts.sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf()).slice(0, 5);
---

<div class="bg-white rounded-3xl border border-gray-100 p-6 sm:p-8 shadow-sm">
  <div class="flex items-center gap-3 mb-6 pb-4 border-b border-gray-100">
    <div class="w-1.5 h-6 bg-blue-600 rounded-full"></div>
    <h3 class="text-lg font-bold text-gray-900 tracking-tight">บทความอ่านล่าสุด</h3>
  </div>
  
  <ul class="flex flex-col gap-5">
    {posts.map((post) => (
      <li>
        <a href={`/blog/${post.id}`} class="group flex gap-4 items-start">
          <div class="shrink-0 w-20 h-20 rounded-2xl overflow-hidden bg-gray-100 relative">
            {post.data.cover ? (
              <Image 
                src={post.data.cover} 
                alt={post.data.title} 
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                width={80}
                height={80}
              />
            ) : (
              <div class="w-full h-full bg-blue-50 flex items-center justify-center text-blue-200">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg>
              </div>
            )}
          </div>
          <div class="flex-1">
            <h4 class="text-sm font-bold text-gray-900 leading-snug group-hover:text-blue-600 transition-colors line-clamp-2 mb-1.5">
              {post.data.title}
            </h4>
            <time class="text-xs text-gray-500 font-medium">
              {post.data.publishedAt.toLocaleDateString('th-TH', { year: 'numeric', month: 'short', day: 'numeric' })}
            </time>
          </div>
        </a>
      </li>
    ))}
  </ul>
</div>
