---
import { Image } from 'astro:assets';
import featuredImg from '@/assets/blogs/คู่มือเริ่มต้น.png';
---

<section class="mb-32 py-16 sm:py-20 lg:py-24 px-6 sm:px-12 lg:px-20 bg-gradient-to-br from-blue-50/50 to-indigo-50/30 rounded-[3rem] relative overflow-hidden">
  {/* Decorative Background Elements */}
  <div class="absolute top-0 right-0 w-[800px] h-[800px] bg-white rounded-full opacity-60 blur-3xl -translate-y-1/2 translate-x-1/3 pointer-events-none"></div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24 items-center relative z-10 max-w-6xl mx-auto">
    
    {/* Left: Content */}
    <div class="order-2 lg:order-1">
      <span class="text-blue-600 font-bold tracking-wider uppercase text-xs mb-4 block">บทความแนะนำ</span>
      <h2 class="text-4xl sm:text-5xl font-bold text-gray-900 leading-[1.1] mb-6">
        คู่มือเริ่มต้น<br/>
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-600 to-indigo-600">สร้างแบรนด์เสื้อผ้า</span><br/>
        ฉบับสมบูรณ์
      </h2>
      <p class="text-gray-600 text-lg leading-relaxed mb-8 max-w-md">
        เจาะลึกทุกขั้นตอนตั้งแต่การหาไอเดีย เลือกเนื้อผ้า เทคนิคงานสกรีน ไปจนถึงการทำการตลาด ให้แบรนด์ของคุณโดดเด่นและทำกำไรได้จริง
      </p>
      
      <div class="flex flex-wrap items-center gap-4 mb-10">
        <a href="/blog/clothing-brand-startup-guide" class="inline-flex items-center justify-center px-8 py-3.5 text-sm font-semibold text-white bg-gray-900 rounded-full hover:bg-gray-800 transition-colors shadow-md">
          อ่านบทความนี้
        </a>
      </div>

      <div class="flex items-center gap-8 pt-8 border-t border-gray-200">
        <div>
          <p class="text-3xl font-bold text-gray-900 mb-1">10k+</p>
          <p class="text-xs text-gray-500 font-medium uppercase tracking-wide">ผู้อ่านทั้งหมด</p>
        </div>
        <div>
          <p class="text-3xl font-bold text-gray-900 mb-1">5 นาที</p>
          <p class="text-xs text-gray-500 font-medium uppercase tracking-wide">เวลาที่ใช้อ่าน</p>
        </div>
      </div>
    </div>

    {/* Right: Large Image */}
    <div class="order-1 lg:order-2">
      <div class="relative w-full aspect-[4/5] sm:aspect-square lg:aspect-[3/4] rounded-[2rem] sm:rounded-[3rem] overflow-hidden shadow-2xl">
        <Image
          src={featuredImg}
          alt="คู่มือเริ่มต้นสร้างแบรนด์เสื้อผ้า"
          class="w-full h-full object-cover"
        />
        <div class="absolute bottom-6 left-6 right-6">
          <div class="bg-white/90 backdrop-blur-md rounded-2xl p-4 flex items-center gap-4">
            <div class="w-12 h-12 bg-blue-100 rounded-full flex items-center justify-center text-blue-600 shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4Z"/></svg>
            </div>
            <div>
              <p class="text-sm font-bold text-gray-900">เขียนโดย ผู้เชี่ยวชาญ</p>
              <p class="text-xs text-gray-500">ทีมงาน Thana Plus 153</p>
            </div>
          </div>
        </div>
      </div>
    </div>

  </div>
</section>
