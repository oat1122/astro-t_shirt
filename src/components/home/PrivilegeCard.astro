---
import Icon from '@/components/Icon.astro';
import type { ComponentProps } from 'astro/types';

interface Props {
  /** ชื่อ icon — ใช้ชื่อเดียวกับที่ลงทะเบียนไว้ใน Icon.astro */
  icon: ComponentProps<typeof Icon>['name'];
  /** หัวข้อสิทธิพิเศษ เช่น "ออกแบบฟรี" */
  title: string;
  /** คำอธิบายสั้น ๆ ใต้หัวข้อ */
  description: string;
  /** สลับทิศหมุน icon ตอน hover (การ์ดคู่หมุนกลับด้าน) */
  reverse?: boolean;
}

const { icon, title, description, reverse = false } = Astro.props;
---

<div class="group relative bg-white rounded-[2rem] p-8 border border-gray-100 shadow-sm hover:shadow-2xl hover:shadow-gray-200/50 hover:border-gray-200 transition-all duration-500 hover:-translate-y-2 overflow-hidden">
  {/* รูปทรงตกแต่งที่ขยายตอน hover */}
  <div class="absolute -right-8 -top-8 w-32 h-32 bg-gray-50 rounded-full transition-transform duration-700 group-hover:scale-[2] group-hover:bg-gray-100/50 z-0"></div>

  <div class="relative z-10">
    <div
      class:list={[
        'w-16 h-16 rounded-2xl flex items-center justify-center mb-8 border border-gray-100 bg-white text-gray-900 shadow-sm transition-all duration-500 group-hover:scale-110 group-hover:bg-gray-900 group-hover:text-white group-hover:border-gray-900',
        reverse ? 'group-hover:-rotate-3' : 'group-hover:rotate-3',
      ]}
    >
      <Icon name={icon} size={28} />
    </div>
    <h3 class="text-xl font-bold text-gray-900 mb-3 group-hover:text-black transition-colors duration-300">{title}</h3>
    <p class="text-gray-500 text-sm leading-relaxed group-hover:text-gray-700 transition-colors duration-300">{description}</p>
  </div>
</div>
