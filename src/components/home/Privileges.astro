---
import PrivilegeCard from './PrivilegeCard.astro';

// สิทธิพิเศษแต่ละข้อ — เพิ่ม/แก้ได้ที่ array นี้ที่เดียว
const privileges = [
  {
    icon: 'palette',
    title: 'ออกแบบฟรี',
    description: 'ทีมกราฟิกมืออาชีพพร้อมให้คำปรึกษาและออกแบบลายเสื้อให้คุณฟรี ไม่มีค่าใช้จ่ายแฝง',
  },
  {
    icon: 'truck-delivery',
    title: 'ส่งฟรีทั่วกรุงเทพฯ',
    description: 'บริการจัดส่งฟรีในเขตกรุงเทพฯ และปริมณฑล สินค้าถึงมือตรงเวลาและปลอดภัย',
  },
  {
    icon: 'shirt',
    title: 'ขึ้นตัวอย่างฟรี',
    description: 'มั่นใจในคุณภาพก่อนผลิตจริง ด้วยบริการขึ้นตัวอย่างสินค้าฟรีเมื่อสั่งจำนวนถึงเกณฑ์',
  },
  {
    icon: 'clock-hour-4',
    title: 'ประเมินราคาไว',
    description: 'ตอบกลับรวดเร็ว เสนอราคาชัดเจน โปร่งใส ช่วยให้คุณวางแผนงบประมาณได้ง่ายขึ้น',
  },
] as const;
---

{/* Privileges Section */}
<section class="mt-32 relative z-20 py-16">
  <div class="mb-16 text-center relative">
    <h2 class="text-4xl md:text-5xl font-extrabold text-gray-900 tracking-tight mb-6">
      สิทธิพิเศษและ<span class="text-transparent bg-clip-text bg-gradient-to-r from-gray-900 to-gray-500">โปรโมชั่นสั่งทำเสื้อ</span>
    </h2>
    <p class="text-gray-500 text-lg max-w-2xl mx-auto leading-relaxed">คุ้มค่ากว่าเมื่อสั่งผลิตกับเรา พร้อมบริการเสริมฟรีเพื่อแบรนด์ของคุณที่ครบจบในที่เดียว</p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
    {/* การ์ดคู่ (index คี่) หมุน icon กลับด้านตอน hover เพื่อให้ดูมีจังหวะ */}
    {privileges.map((p, i) => <PrivilegeCard {...p} reverse={i % 2 === 1} />)}
  </div>
</section>
