---
import { Image } from 'astro:assets';
import heroImg from '@/assets/home/Privileges/hero.png';
import designFreeImg from '@/assets/home/Privileges/บริการออกแบบก่อน-ผลิตเสื้อ.png';
import screenFreeImg from '@/assets/home/Privileges/silk-screen.png';
import shippingFreeImg from '@/assets/home/Privileges/จัดส่งเสื้อยืดหลังจาก-ผลิตเสื้อยืดเสร็จ.png';
import consultFreeImg from '@/assets/home/Privileges/ปรึกษาฟรี.png';
---
{/* Privileges Section */}
<section class="mt-24 lg:mt-32 relative z-20 py-8">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-16 items-center">
      
      {/* Left Column - Main Image */}
      <div class="lg:col-span-4 flex justify-center lg:justify-end">
        <div class="w-full max-w-md lg:max-w-none rounded-[2rem] overflow-hidden shadow-sm border border-gray-100 group">
          <Image 
            src={heroImg} 
            alt="ผลิตเสื้อ ผลิตเสื้อยืด ครบวงจร" 
            class="w-full h-auto object-cover transform group-hover:scale-105 transition-transform duration-700" 
          />
        </div>
      </div>

      {/* Right Column - Content */}
      <div class="lg:col-span-8 flex flex-col">
        <div class="mb-10 text-left">
          <h2 class="text-3xl md:text-4xl lg:text-5xl font-extrabold tracking-tight mb-6 uppercase">
            <span class="text-transparent bg-clip-text bg-gradient-to-r from-gray-900 to-gray-500">ผลิตเสื้อบริการครบวงจร</span>
          </h2>
          <div class="text-gray-600 text-base md:text-lg space-y-4 leading-relaxed">
            <p class="indent-8">
              ผลิตเสื้อ แบบครบวงจรตั้งแต่ เลือกเนื้อผ้า ตัดเย็บ สกรีนบล็อค สกรีนดิจิตอล ตรวจสอบความเรียบร้อย แพ็คใส่ถุง จัดส่งจนถึงมือท่าน ขั้นตอนเหล่านี้มีความยุ่งยากสูง และยากขึ้นไปอีกขั้นหากต้องควบคุมคุณภาพของชิ้นงาน ซึ่งเราดูแลให้ท่านทั้งหมด เราผลิตด้วยเครื่องจักรทุกขั้นตอน มีช่างมืออาชีพดูแลทุกขั้นตอน พร้อมให้คำปรึกษาจากมืออาชีพ
            </p>
            <p class="indent-8">
              พร้อมบริการช่วยออกแบบ แถมฟรีอีก 2 ชั้น เมื่อสั่งผลิตเสื้อครบ 100 ตัว สกรีนฟรี 1 สี 1 จุด ถ้าสั่งผลิตครบ 20,000 บาท ส่งฟรี (เฉพาะในกรุงเทพฯ)
            </p>
          </div>
        </div>

        <div class="grid grid-cols-2 md:grid-cols-4 gap-6 lg:gap-8 items-start">
          {/* Box 1 */}
          <div class="flex flex-col items-center text-center group cursor-pointer">
            <div class="w-[60%] lg:w-[70%] aspect-square mb-4 overflow-hidden rounded-2xl shadow-sm border border-gray-100 group-hover:shadow-md group-hover:border-gray-200 transition-all duration-500 group-hover:-translate-y-1 bg-white">
              <Image 
                src={designFreeImg} 
                alt="บริการออกแบบก่อน ผลิตเสื้อ" 
                class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700"
              />
            </div>
            <h3 class="text-base md:text-lg font-bold text-gray-900 mb-1 uppercase tracking-wide group-hover:text-black transition-colors">Design Free</h3>
            <p class="text-gray-500 text-xs md:text-sm group-hover:text-gray-700 transition-colors">บริการช่วยออกแบบ</p>
          </div>

          {/* Box 2 */}
          <div class="flex flex-col items-center text-center group cursor-pointer">
            <div class="w-[60%] lg:w-[70%] aspect-square mb-4 overflow-hidden rounded-2xl shadow-sm border border-gray-100 group-hover:shadow-md group-hover:border-gray-200 transition-all duration-500 group-hover:-translate-y-1 bg-white">
              <Image 
                src={screenFreeImg} 
                alt="สกรีนฟรี 1 จุด" 
                class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700"
              />
            </div>
            <h3 class="text-base md:text-lg font-bold text-gray-900 mb-1 uppercase tracking-wide group-hover:text-black transition-colors">Screen Free</h3>
            <p class="text-gray-500 text-xs md:text-sm group-hover:text-gray-700 transition-colors">สกรีนฟรี จำนวน 1 จุด</p>
          </div>

          {/* Box 3 */}
          <div class="flex flex-col items-center text-center group cursor-pointer">
            <div class="w-[60%] lg:w-[70%] aspect-square mb-4 overflow-hidden rounded-2xl shadow-sm border border-gray-100 group-hover:shadow-md group-hover:border-gray-200 transition-all duration-500 group-hover:-translate-y-1 bg-white">
              <Image 
                src={shippingFreeImg} 
                alt="จัดส่งเสื้อยืดหลังจาก ผลิตเสื้อยืดเสร็จ" 
                class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700"
              />
            </div>
            <h3 class="text-base md:text-lg font-bold text-gray-900 mb-1 uppercase tracking-wide group-hover:text-black transition-colors">Shipping Free</h3>
            <p class="text-gray-500 text-xs md:text-sm group-hover:text-gray-700 transition-colors">บริการจัดส่งฟรี</p>
          </div>

          {/* Box 4 */}
          <div class="flex flex-col items-center text-center group cursor-pointer">
            <div class="w-[60%] lg:w-[70%] aspect-square mb-4 overflow-hidden rounded-2xl shadow-sm border border-gray-100 group-hover:shadow-md group-hover:border-gray-200 transition-all duration-500 group-hover:-translate-y-1 bg-white">
              <Image 
                src={consultFreeImg} 
                alt="ให้คำปรึกษาฟรี" 
                class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700"
              />
            </div>
            <h3 class="text-base md:text-lg font-bold text-gray-900 mb-1 uppercase tracking-wide group-hover:text-black transition-colors">Consult Free</h3>
            <p class="text-gray-500 text-xs md:text-sm group-hover:text-gray-700 transition-colors">ให้คำปรึกษาฟรี</p>
          </div>
        </div>
        
      </div>
    </div>
  </div>
</section>
