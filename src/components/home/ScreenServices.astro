---
import { Button } from '@/components/starwind/button';
---

{/* Screen Printing & Embroidery Section */}
<section class="mt-32 relative z-20">
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
    
    <div class="order-2 lg:order-1 rounded-[2rem] overflow-hidden">
      <img 
        src="https://images.unsplash.com/photo-1620799140408-edc6dcb6d633?auto=format&fit=crop&q=80&w=800" 
        alt="Screen Printing Services" 
        class="w-full h-auto object-cover aspect-[4/3] transform hover:scale-105 transition-transform duration-700"
      />
    </div>

    <div class="order-1 lg:order-2 flex flex-col items-start text-left">
      <h2 class="text-3xl md:text-4xl font-bold text-gray-900 tracking-tight mb-6">บริการรับสกรีนเสื้อและงานพิมพ์ผ้า</h2>
      <p class="text-gray-600 text-lg mb-8 leading-relaxed">
        ตอบโจทย์ทุกงานดีไซน์ด้วยเทคนิคการสกรีนและงานปักที่หลากหลาย ควบคุมคุณภาพทุกขั้นตอนเพื่อให้ได้สีสันที่คมชัดและทนทาน ไม่ว่าจะเป็นงานซิลค์สกรีน, DFT, Sublimation หรืองานปักคอมพิวเตอร์
      </p>
      
      <ul class="flex flex-col gap-4 mb-10 w-full">
        <li class="flex items-start gap-3">
          <div class="mt-1 bg-black text-white rounded-full p-1"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg></div>
          <div>
            <strong class="text-gray-900 font-semibold block">ซิลค์สกรีน (Silk Screen)</strong>
            <span class="text-gray-500 text-sm">สีสด ทนทาน เหมาะสำหรับการผลิตจำนวนมาก</span>
          </div>
        </li>
        <li class="flex items-start gap-3">
          <div class="mt-1 bg-black text-white rounded-full p-1"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg></div>
          <div>
            <strong class="text-gray-900 font-semibold block">งานพิมพ์ DFT / DTG</strong>
            <span class="text-gray-500 text-sm">พิมพ์ลายได้ไม่จำกัดสี เก็บรายละเอียดได้คมชัด</span>
          </div>
        </li>
        <li class="flex items-start gap-3">
          <div class="mt-1 bg-black text-white rounded-full p-1"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg></div>
          <div>
            <strong class="text-gray-900 font-semibold block">งานปักคอมพิวเตอร์</strong>
            <span class="text-gray-500 text-sm">ดูพรีเมียม หรูหรา เหมาะสำหรับเสื้อโปโลและยูนิฟอร์ม</span>
          </div>
        </li>
      </ul>

      <Button class="rounded-full bg-black hover:bg-gray-800 text-white px-8 py-6 text-base shadow-lg transition-transform hover:scale-105">
        ดูรายละเอียดงานสกรีน
      </Button>
    </div>

  </div>
</section>
