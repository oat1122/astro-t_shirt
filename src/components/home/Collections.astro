---
import CollectionCard from './CollectionCard.astro';

const collections = [
  { title: "T-Shirts", image: "/images/home/T-Shirts_Collection.png", alt: "T-Shirts Manufacturing" },
  { title: "Polo Shirts", image: "/images/home/Polo-Shirts_Collection.png", alt: "Polo Shirts Manufacturing" },
  { title: "Uniforms", image: "https://images.unsplash.com/photo-1584908688463-c7fb8fcbc9bb?auto=format&fit=crop&q=80&w=600", alt: "Uniforms Manufacturing" },
];

// การ์ดสุดท้ายวางคู่กับปุ่ม next จึงดึงออกมาแยก
const featured = collections.slice(0, -1);
const last = collections[collections.length - 1];
---

{/* Collections Section */}
<section class="mt-32 lg:mt-24 relative z-20">
  <!-- <div class="mb-10 text-center">
    <h2 class="text-3xl md:text-4xl font-bold text-gray-900 tracking-tight">บริการรับผลิตเสื้อและสินค้าของเรา</h2>
    <p class="text-gray-500 mt-4 text-base max-w-2xl mx-auto">เลือกแบบเสื้อที่คุณต้องการ เรามีบริการรับผลิตครบวงจรพร้อมให้คำปรึกษา</p>
  </div> -->

  <div class="grid grid-cols-1 md:grid-cols-3 gap-6">

  {featured.map((c) => <CollectionCard {...c} />)}

  {/* Card สุดท้าย */}
  <div class="flex gap-4 items-center">
    <CollectionCard {...last} flex />
  </div>

  </div>
</section>
