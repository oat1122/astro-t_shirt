---
import { Button } from '@/components/starwind/button';

interface ProcessItem {
  id: string;
  name: string;
  category: string;
  subtitle: string;
  image: string;
}

const trendingItems: ProcessItem[] = [
  {
    id: '1',
    name: 'Pattern Design',
    category: 'Step 01',
    subtitle: 'Precision fit',
    image: 'https://images.unsplash.com/photo-1556909211-3698d532d7ea?auto=format&fit=crop&q=80&w=600'
  },
  {
    id: '2',
    name: 'Fabric Cutting',
    category: 'Step 02',
    subtitle: 'High accuracy',
    image: 'https://images.unsplash.com/photo-1598020815255-081831d0ebbb?auto=format&fit=crop&q=80&w=600'
  },
  {
    id: '3',
    name: 'Screen Printing',
    category: 'Step 03',
    subtitle: 'Vibrant colors',
    image: 'https://images.unsplash.com/photo-1620799140408-edc6dcb6d633?auto=format&fit=crop&q=80&w=600'
  },
  {
    id: '4',
    name: 'Sewing & QC',
    category: 'Step 04',
    subtitle: 'Quality control',
    image: 'https://images.unsplash.com/photo-1612423284934-2850a4ea6b0f?auto=format&fit=crop&q=80&w=600'
  }
];
---

<div class="mt-24 lg:mt-32">
  <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-12 items-center">
    
    {/* Left Column - Typography & CTA (1/3 approx) */}
    <div class="lg:col-span-4 flex flex-col items-start z-10">
      <div class="flex items-center gap-3 mb-6">
        <span class="w-12 h-[1px] bg-gray-900"></span>
        <span class="text-sm font-semibold tracking-widest uppercase text-gray-900">Our Expertise</span>
      </div>

      <h2 class="text-[4rem] sm:text-[5rem] lg:text-[5.5rem] leading-[0.9] font-bold tracking-tight text-gray-900 mb-6 flex flex-col">
        <span>Production</span>
        <span class="text-gray-400 font-light tracking-normal italic">Process</span>
      </h2>

      <p class="text-gray-600 max-w-sm leading-relaxed mb-8 text-base">
        กระบวนการผลิตที่ได้มาตรฐานระดับสากล ใส่ใจทุกรายละเอียดตั้งแต่การเลือกผ้าจนถึงการตัดเย็บและการบรรจุ
      </p>

      <Button class="rounded-full bg-transparent hover:bg-gray-100 text-black border border-gray-200 px-8 py-6 text-base shadow-sm transition-transform hover:scale-105">
        Learn More
      </Button>
    </div>

    {/* Right Column - Auto-scrolling Marquee (2/3 approx) */}
    <div class="lg:col-span-8 marquee group/marquee">
      {/* Track: รายการถูก render ซ้ำ 2 ชุดเพื่อให้ลูปต่อเนื่องแบบไร้รอยต่อ */}
      <div class="marquee-track flex gap-4 sm:gap-6 py-4">
        {[...trendingItems, ...trendingItems].map((item, i) => (
          <div
            class="shrink-0 w-[240px] sm:w-[280px] bg-white rounded-3xl p-4 shadow-[0_4px_20px_-10px_rgba(0,0,0,0.05)] border border-gray-100 group cursor-pointer hover:shadow-md transition-shadow flex flex-col"
            aria-hidden={i >= trendingItems.length ? 'true' : undefined}
          >
            <div class="w-full aspect-[3/4] rounded-2xl overflow-hidden bg-gray-100 mb-4 relative">
              <img src={item.image} alt={item.name} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />

              {/* Hover Icon */}
              <div class="absolute top-3 right-3 bg-white/90 backdrop-blur-sm rounded-full p-2 opacity-0 group-hover:opacity-100 transition-opacity duration-300 shadow-sm text-black">
                 <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17 17 7"/><path d="M7 7h10v10"/></svg>
              </div>
            </div>
            <div class="flex flex-col gap-1 px-2">
              <span class="text-[10px] sm:text-xs font-semibold uppercase tracking-wider text-gray-400">{item.category}</span>
              <h3 class="text-base sm:text-lg font-bold text-gray-900 truncate">{item.name}</h3>
              <p class="text-sm sm:text-base font-bold text-gray-500 mt-1">{item.subtitle}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
    
  </div>
</div>

<style>
  /* Marquee: ตัดส่วนที่ล้นออก + เฟดขอบซ้าย/ขวาให้ดูนุ่ม */
  .marquee {
    overflow: hidden;
    -webkit-mask-image: linear-gradient(
      to right,
      transparent 0,
      #000 5%,
      #000 95%,
      transparent 100%
    );
    mask-image: linear-gradient(
      to right,
      transparent 0,
      #000 5%,
      #000 95%,
      transparent 100%
    );
  }

  /* เลื่อนไป -50% = ความกว้างของชุดแรกพอดี ∴ ลูปต่อเนื่องไร้รอยต่อ */
  .marquee-track {
    width: max-content;
    animation: marquee-scroll 40s linear infinite;
  }

  /* หยุดเมื่อ hover เพื่อให้ผู้ใช้ดูสินค้าได้ */
  .marquee:hover .marquee-track {
    animation-play-state: paused;
  }

  @keyframes marquee-scroll {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(-50%);
    }
  }

  /* เคารพผู้ใช้ที่ลดการเคลื่อนไหว: ไม่เลื่อนอัตโนมัติ */
  @media (prefers-reduced-motion: reduce) {
    .marquee {
      overflow-x: auto;
      -webkit-mask-image: none;
      mask-image: none;
    }
    .marquee-track {
      animation: none;
    }
  }
</style>
