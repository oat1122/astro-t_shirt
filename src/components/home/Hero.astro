---
import { Image } from 'astro:assets';
import Icon from '@/components/Icon.astro';
import heroImg from '@/assets/home/hero-img.png';
---

{/* Hero Section */}
<div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-start relative lg:min-h-[600px]">

  {/* Left Column - Typography & CTAs */}
  <div class="lg:col-span-7 flex flex-col z-10 pt-10">

    <h1 class="text-4xl sm:text-5xl lg:text-6xl leading-[1.1] font-bold tracking-tight text-gray-900 mb-6 flex flex-col">
      <span>โรงงานรับผลิตเสื้อครบวงจร</span>
      <span class="text-gray-500 font-medium tracking-normal text-3xl sm:text-4xl mt-2">ครบจบในที่เดียว ตั้งแต่เลือกผ้าถึงงานสกรีน</span>
    </h1>

    <div class="flex flex-col sm:flex-row items-start sm:items-center gap-8 mt-12">
      <p class="text-gray-600 max-w-[200px] leading-snug">บริการรับผลิตเสื้อผ้าครบวงจร ยกระดับแบรนด์ของคุณด้วยคุณภาพระดับมาตรฐาน</p>
    </div>

  </div>

  {/* Right Column - Large Image */}
  <div class="lg:col-span-5 relative mt-12 lg:mt-0 lg:absolute lg:right-0 lg:top-0 lg:w-[45%] lg:h-[120%] pointer-events-none">
    {/* Background Circle */}
    <div class="absolute inset-0 bg-[#F0F0F0] rounded-full aspect-square w-[80%] mx-auto lg:mx-0 lg:w-full lg:-right-[10%] lg:-top-[10%] -z-10 mix-blend-multiply"></div>

    {/* Main Factory Image — LCP element: eager + high priority, astro:assets แปลง WebP/AVIF + ใส่ขนาดกัน CLS */}
    <Image
      src={heroImg}
      alt="โรงงานรับผลิตเสื้อผ้าครบวงจร งานตัดเย็บและสกรีนเสื้อ"
      widths={[480, 768, 1019]}
      sizes="(min-width: 1024px) 45vw, 80vw"
      loading="eager"
      fetchpriority="high"
      class="w-full h-auto object-cover rounded-[3rem] lg:rounded-none lg:bg-transparent lg:object-cover relative z-0 pointer-events-auto transform lg:scale-110 lg:translate-y-12"
      style="mask-image: linear-gradient(to bottom, black 80%, transparent 100%); -webkit-mask-image: linear-gradient(to bottom, black 80%, transparent 100%);"
    />

    {/* Floating Social Proof */}
    <div class="absolute top-[10%] right-0 lg:-right-8 bg-white/80 backdrop-blur-md px-4 py-3 rounded-2xl shadow-sm border border-gray-100 flex flex-col gap-2 pointer-events-auto">
      <div class="flex items-center gap-1.5 text-gray-700">
        <Icon name="building-factory-2" size={20} />
        <Icon name="star" size={20} />
        <Icon name="trophy" size={20} />
        <Icon name="heart-handshake" size={20} />
        <Icon name="shirt" size={20} />
      </div>
      <p class="text-xs font-semibold text-gray-800 underline decoration-gray-300 underline-offset-4">Trusted by 500+ Brands</p>
    </div>

  </div>

</div>
