---
// Navbar — แถบนำทางส่วนหัวของหน้าเว็บ
import { Image } from 'astro:assets';
import logo from '@/assets/logo.png';
---

<header class="flex items-center justify-between px-8 py-6 lg:px-12">
  <a href="/" class="flex items-center gap-2">
    <Image src={logo} alt="Thana Plus" width={32} height={32} class="w-8 h-8" />
    <span class="text-xl font-bold tracking-tight">Thana Plus</span>
  </a>

  <nav class="hidden md:flex items-center gap-8 text-sm font-medium">
    <a href="#" class="flex items-center gap-1 hover:text-gray-600 transition-colors">Services <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg></a>
    <a href="#" class="hover:text-gray-600 transition-colors">Portfolio</a>
    <a href="#" class="hover:text-gray-600 transition-colors">Process</a>
    <a href="#" class="hover:text-gray-600 transition-colors">Contact Us</a>
  </nav>
</header>
