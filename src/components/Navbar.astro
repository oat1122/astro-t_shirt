---
// Navbar — แถบนำทางส่วนหัวของหน้าเว็บ
import { Image } from 'astro:assets';
import logo from '@/assets/logo.png';

// เมนูย่อยใต้ปุ่ม Services — ลิงก์ลึกไปแต่ละ section ของหน้า /services
// ทำให้ลูกศร chevron มีความหมาย + เพิ่ม internal link ที่ดีต่อ SEO
const serviceMenu = [
  { label: 'บริการทั้งหมด', desc: 'รับผลิตเสื้อครบวงจร', href: '/services#services' },
  { label: 'งานสกรีน & งานพิมพ์', desc: 'ซิลค์สกรีน · DTG/DTF · Sublimation', href: '/services#screen' },
  { label: 'ขั้นตอนการสั่งผลิต', desc: 'สั่งผลิตง่ายใน 6 ขั้นตอน', href: '/services#process' },
  { label: 'คำถามที่พบบ่อย', desc: 'ราคา · ขั้นต่ำ · ระยะเวลา', href: '/services#faq-heading' },
] as const;
---

<header class="flex items-center justify-between px-8 py-6 lg:px-12">
  <a href="/" class="flex items-center gap-2">
    <Image src={logo} alt="เสื้อแท้ ธน พลัส 153" width={32} height={32} class="w-8 h-8" />
    <span class="text-xl font-bold tracking-tight">เสื้อแท้</span>
  </a>

  <nav class="hidden md:flex items-center gap-8 text-sm font-medium">
    {/* Services — dropdown แบบ zero-JS (แสดงเมื่อ hover หรือ keyboard focus เข้าในกลุ่ม) */}
    <div class="relative group">
      <a
        href="/services"
        class="flex items-center gap-1 hover:text-gray-600 transition-colors"
        aria-haspopup="true"
      >
        Services
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform duration-200 group-hover:rotate-180 group-focus-within:rotate-180" aria-hidden="true"><path d="m6 9 6 6 6-6"/></svg>
      </a>

      <div class="invisible absolute left-0 top-full z-50 pt-3 opacity-0 translate-y-1 transition-all duration-200 group-hover:visible group-hover:opacity-100 group-hover:translate-y-0 group-focus-within:visible group-focus-within:opacity-100 group-focus-within:translate-y-0">
        <ul class="w-72 rounded-2xl border border-gray-100 bg-white p-2 shadow-xl">
          {serviceMenu.map((m) => (
            <li>
              <a href={m.href} class="block rounded-xl px-4 py-2.5 hover:bg-gray-50 transition-colors">
                <span class="block font-semibold text-gray-900">{m.label}</span>
                <span class="block text-xs text-gray-500">{m.desc}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <a href="/blog" class="hover:text-gray-600 transition-colors">Blog</a>
    <a href="/products" class="hover:text-gray-600 transition-colors">Products</a>
    <a href="/services#contact" class="hover:text-gray-600 transition-colors">Contact Us</a>
  </nav>
</header>
