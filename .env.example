# ─────────────────────────────────────────────────────────────
# ตัวอย่างไฟล์ environment — คัดลอกเป็น .env แล้วใส่ค่าจริง
#   cp .env.example .env
# .env / .env.production ถูก gitignore ไว้ (ไม่ commit ค่าจริง)
# ─────────────────────────────────────────────────────────────

# โดเมนจริงของเว็บ (ต้องมี protocol, ลงท้ายด้วย /)
# มีผลต่อ: sitemap.xml, robots.txt (host + sitemap ref), rss.xml, canonical URL, OG image URL
# อ่านโดย astro.config.mjs -> ส่งเข้า defineConfig({ site })
# ถ้าไม่ตั้งค่า จะ fallback เป็นค่า default ใน astro.config.mjs
SITE_URL="http://localhost:4321/"
